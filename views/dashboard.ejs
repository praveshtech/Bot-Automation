<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Vault | Executive Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Premium Glass Effect */
        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
            border-radius: 1rem;
        }
        .text-gradient {
            background: linear-gradient(135deg, #f87171, #dc2626);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body class="bg-gray-900 text-white font-sans min-h-screen p-4 md:p-8" style="background-image: radial-gradient(circle at top right, #1e293b, #0f172a);">

    <div class="max-w-7xl mx-auto">
        <header class="flex flex-col md:flex-row items-center justify-between mb-8 pb-4 border-b border-gray-800">
            <div class="mb-4 md:mb-0 text-center md:text-left">
                <h1 class="text-3xl md:text-4xl font-black uppercase tracking-widest text-gradient">
                    <i class="fa-solid fa-building-columns mr-2 text-red-500"></i> The Vault
                </h1>
                <p class="text-gray-400 mt-1 text-sm font-medium tracking-wide">Live Transaction Monitoring System</p>
            </div>
            <div class="glass-panel px-5 py-2 flex items-center space-x-3">
                <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_#22c55e]"></div>
                <span class="font-bold text-gray-200 tracking-wider text-sm uppercase">Network Online</span>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="glass-panel p-6 border-t-4 border-blue-500 hover:-translate-y-1 transition duration-300">
                <div class="flex justify-between items-center">
                    <h3 class="text-gray-400 text-xs font-bold uppercase tracking-widest">Live Members</h3>
                    <i class="fa-solid fa-users text-blue-500 bg-blue-500/10 p-2 rounded-lg"></i>
                </div>
                <p class="text-3xl font-black mt-4"><%= liveMembers %></p>
            </div>
            <div class="glass-panel p-6 border-t-4 border-green-500 hover:-translate-y-1 transition duration-300">
                <div class="flex justify-between items-center">
                    <h3 class="text-gray-400 text-xs font-bold uppercase tracking-widest">Daily (24h)</h3>
                    <i class="fa-solid fa-bolt text-green-500 bg-green-500/10 p-2 rounded-lg"></i>
                </div>
                <p class="text-3xl font-black text-green-400 mt-4">$<%= dailyVol.toLocaleString() %></p>
            </div>
            <div class="glass-panel p-6 border-t-4 border-yellow-500 hover:-translate-y-1 transition duration-300">
                <div class="flex justify-between items-center">
                    <h3 class="text-gray-400 text-xs font-bold uppercase tracking-widest">Weekly (7D)</h3>
                    <i class="fa-solid fa-calendar-week text-yellow-500 bg-yellow-500/10 p-2 rounded-lg"></i>
                </div>
                <p class="text-3xl font-black text-yellow-400 mt-4">$<%= weeklyVol.toLocaleString() %></p>
            </div>
            <div class="glass-panel p-6 border-t-4 border-purple-500 hover:-translate-y-1 transition duration-300">
                <div class="flex justify-between items-center">
                    <h3 class="text-gray-400 text-xs font-bold uppercase tracking-widest">Monthly (30D)</h3>
                    <i class="fa-solid fa-chart-pie text-purple-500 bg-purple-500/10 p-2 rounded-lg"></i>
                </div>
                <p class="text-3xl font-black text-purple-400 mt-4">$<%= monthlyVol.toLocaleString() %></p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="glass-panel p-6 lg:col-span-2">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-lg font-bold text-gray-200 tracking-wide uppercase"><i class="fa-solid fa-chart-line mr-2 text-blue-400"></i> Revenue Trajectory</h2>
                </div>
                <div class="relative h-72 w-full">
                    <canvas id="volumeChart"></canvas>
                </div>
            </div>

            <div class="glass-panel p-6">
                <h2 class="text-lg font-bold text-gray-200 mb-6 tracking-wide uppercase"><i class="fa-solid fa-crown mr-2 text-yellow-400"></i> Top Network Whales</h2>
                
                <div class="space-y-3">
                    <% if (topTraders.length === 0) { %>
                        <p class="text-gray-500 text-center py-8 italic">No completed trades yet.</p>
                    <% } else { %>
                        <% topTraders.forEach((trader, index) => { %>
                            <div class="flex items-center justify-between p-3 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:bg-slate-700/50 transition">
                                <div class="flex items-center space-x-3">
                                    <% if (index === 0) { %>
                                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-yellow-300 to-yellow-600 flex items-center justify-center font-bold text-black shadow-[0_0_10px_rgba(234,179,8,0.4)]">1</div>
                                    <% } else if (index === 1) { %>
                                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-gray-300 to-gray-500 flex items-center justify-center font-bold text-black">2</div>
                                    <% } else if (index === 2) { %>
                                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-orange-400 to-orange-700 flex items-center justify-center font-bold text-white">3</div>
                                    <% } else { %>
                                        <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center font-bold text-gray-400"><%= index + 1 %></div>
                                    <% } %>
                                    
                                    <div class="font-bold text-gray-200 tracking-wide truncate max-w-[100px]" title="<%= trader.username %>"><%= trader.username %></div>
                                </div>
                                <div class="font-black text-green-400 bg-green-500/10 px-3 py-1 rounded-lg">
                                    $<%= trader.totalVolume.toLocaleString() %>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>

        </div>
    </div>

    <script>
        const ctx = document.getElementById('volumeChart').getContext('2d');
        
        // Gradients for bars
        const greenGradient = ctx.createLinearGradient(0, 0, 0, 400);
        greenGradient.addColorStop(0, 'rgba(34, 197, 94, 0.9)');
        greenGradient.addColorStop(1, 'rgba(34, 197, 94, 0.1)');

        const yellowGradient = ctx.createLinearGradient(0, 0, 0, 400);
        yellowGradient.addColorStop(0, 'rgba(234, 179, 8, 0.9)');
        yellowGradient.addColorStop(1, 'rgba(234, 179, 8, 0.1)');

        const purpleGradient = ctx.createLinearGradient(0, 0, 0, 400);
        purpleGradient.addColorStop(0, 'rgba(168, 85, 247, 0.9)');
        purpleGradient.addColorStop(1, 'rgba(168, 85, 247, 0.1)');

        const volumeChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Daily (24h)', 'Weekly (7D)', 'Monthly (30D)'],
                datasets: [{
                    data: [Number('<%= dailyVol %>'), Number('<%= weeklyVol %>'), Number('<%= monthlyVol %>')],
                    backgroundColor: [greenGradient, yellowGradient, purpleGradient],
                    borderColor: ['#22c55e', '#eab308', '#a855f7'],
                    borderWidth: 1,
                    borderRadius: 8,
                    barPercentage: 0.5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { 
                        beginAtZero: true, 
                        grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false }, 
                        ticks: { color: '#94a3b8', font: { family: 'sans-serif', size: 12 } },
                        border: { display: false }
                    },
                    x: { 
                        grid: { display: false }, 
                        ticks: { color: '#e2e8f0', font: { weight: 'bold', size: 13 } },
                        border: { display: false }
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.95)',
                        titleColor: '#cbd5e1',
                        bodyColor: '#22c55e',
                        bodyFont: { weight: 'bold', size: 16 },
                        padding: 14,
                        cornerRadius: 10,
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return 'Volume: $' + context.raw.toLocaleString();
                            }
                        }
                    }
                }
            }
        });
    </script>
</body>
</html>