                </div>
            </div>
        </section>

    </main>

    <div id="txModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 overflow-y-auto">
        <div class="absolute inset-0 bg-black/75 backdrop-blur-sm transition-opacity" onclick="closeTxModal()"></div>
        <div class="glass-panel relative z-10 w-full max-w-lg p-5 sm:p-8 border-t-4 border-red-600 transform scale-95 opacity-0 transition-all duration-300" id="txModalContent">
            <button onclick="closeTxModal()" class="absolute top-5 right-5 text-slate-400 hover:text-red-500 transition duration-300 bg-slate-800/50 hover:bg-slate-800 w-8 h-8 rounded-full flex items-center justify-center"><i class="fa-solid fa-xmark text-lg"></i></button>
            <div class="flex items-center mb-6 border-b border-slate-700/50 pb-4">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-slate-700 to-slate-900 flex justify-center items-center mr-4 text-lg font-black text-white shadow-inner border border-slate-600" id="modal-avatar">U</div>
                <div>
                    <h3 class="text-xl sm:text-2xl font-black text-white tracking-tight" id="modal-username">Username</h3>
                    <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mt-1" id="modal-date">Date & Time</p>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4 mb-6">
                <div class="bg-slate-900/60 p-3 sm:p-4 rounded-xl border border-slate-700/50 shadow-inner">
                    <p class="text-[9px] sm:text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-1">Action & Method</p>
                    <p class="font-black text-sm sm:text-lg" id="modal-action">BUY / UPI</p>
                </div>
                <div class="bg-slate-900/60 p-3 sm:p-4 rounded-xl border border-slate-700/50 shadow-inner">
                    <p class="text-[9px] sm:text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-1">Amount</p>
                    <p class="font-black text-lg sm:text-2xl text-white text-glow" id="modal-amount">$0.00</p>
                </div>
            </div>
            <div>
                <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-2 flex items-center"><i class="fa-solid fa-file-invoice mr-2"></i> User Provided Details</p>
                <div class="bg-[#050b14] p-4 sm:p-5 rounded-xl border border-slate-700 text-xs sm:text-sm font-medium text-green-400 whitespace-pre-wrap font-mono shadow-inner max-h-40 overflow-y-auto" id="modal-details">Loading...</div>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-700/50 flex justify-between items-center text-[10px] text-slate-500 font-bold uppercase">
                <span>Closed By: <span id="modal-closedBy" class="text-slate-300">Admin</span></span>
                <span class="text-red-500"><i class="fa-solid fa-shield-check mr-1"></i> Vault Secured</span>
            </div>
        </div>
    </div>

    <div id="kycModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 overflow-y-auto">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity" onclick="closeKycModal()"></div>
        <div class="glass-panel relative z-10 w-full max-w-2xl p-5 sm:p-8 border-t-4 border-yellow-500 transform scale-95 opacity-0 transition-all duration-300" id="kycModalContent">
            
            <button onclick="closeKycModal()" class="absolute top-5 right-5 text-slate-400 hover:text-yellow-500 transition duration-300 bg-slate-800/50 hover:bg-slate-800 w-8 h-8 rounded-full flex items-center justify-center">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
            
            <div class="mb-6 border-b border-slate-700/50 pb-4">
                <h3 class="text-xl sm:text-2xl font-black text-white tracking-tight flex items-center">
                    <i class="fa-solid fa-user-shield text-yellow-500 mr-3"></i> Pending KYC Reviews
                </h3>
                <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mt-1">Review and action the verification requests.</p>
            </div>
            
            <div class="space-y-4 max-h-[350px] sm:max-h-[400px] overflow-y-auto pr-1" id="kyc-list-wrapper">
                <% if (pendingKycList.length === 0) { %>
                    <div class="text-center py-10 text-slate-500 italic">
                        <i class="fa-solid fa-circle-check text-4xl text-green-500/20 mb-3 block"></i>
                        No pending KYC requests. All clear!
                    </div>
                <% } else { %>
                    <% pendingKycList.forEach(kyc => { %>
                        <div class="bg-slate-900/60 p-4 sm:p-5 rounded-xl border border-slate-800 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 transition duration-300 hover:border-slate-700" id="kyc-row-<%= kyc.discordId %>">
                            <div class="flex-1 w-full">
                                <div class="flex items-center space-x-3 mb-2">
                                    <span class="bg-yellow-500/10 text-yellow-400 text-[9px] font-black px-2 py-0.5 rounded uppercase tracking-wider">Pending</span>
                                    <span class="text-xs font-black text-slate-400">ID: <%= kyc.discordContact %></span>
                                </div>
                                <h4 class="font-bold text-white text-sm sm:text-base">Alias: <span class="text-yellow-400"><%= kyc.name %></span></h4>
                                <p class="text-xs text-slate-400 mt-1">Tag: @<%= kyc.username %></p>
                                <div class="bg-[#050b14]/50 border border-slate-800/80 p-2.5 rounded-lg mt-3 text-xs text-slate-300 font-mono overflow-x-auto">
                                    <span class="text-slate-500 font-bold block mb-1">Details:</span>
                                    <%= kyc.paymentInfo %>
                                </div>
                            </div>
                            <div class="flex md:flex-col gap-2 w-full md:w-auto">
                                <button onclick="actionKyc('<%= kyc.discordId %>', 'approve')" class="flex-1 md:flex-initial w-full md:w-28 bg-green-600 hover:bg-green-700 text-white text-xs font-black uppercase tracking-wider py-2.5 rounded-lg transition-all shadow-[0_0_10px_rgba(34,197,94,0.1)]">
                                    Approve
                                </button>
                                <button onclick="actionKyc('<%= kyc.discordId %>', 'reject')" class="flex-1 md:flex-initial w-full md:w-28 bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white text-xs font-black uppercase tracking-wider py-2.5 rounded-lg border border-red-500/10 transition-all">
                                    Reject
                                </button>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
            
            <div class="mt-6 pt-4 border-t border-slate-700/50 text-right text-[10px] text-slate-500 font-black uppercase tracking-widest">
                <i class="fa-solid fa-clock-rotate-left mr-1"></i> Waiting Queue: <%= pendingKyc %>
            </div>
        </div>
    </div>

    <script>
        const recentTrades = <%- JSON.stringify(recentFeed || []) %>;
    </script>

    <script>
        // --- 🔥 ZERO-READ SMART REFRESH SYSTEM 🔥 ---
        let currentServerTime = Date.now();
        let isSyncPaused = false;
        let syncInterval;

        function startSmartSync() {
            syncInterval = setInterval(async () => {
                if (!isSyncPaused) {
                    try {
                        const response = await fetch('/api/check-updates');
                        const data = await response.json();
                        
                        if (data.timestamp > currentServerTime) {
                            console.log("New data detected! Refreshing dashboard...");
                            window.location.reload();
                        }
                    } catch (error) {
                        console.log("Update check paused/failed.");
                    }
                }
            }, 5000);
        }

        function toggleSmartSync() {
            const icon = document.getElementById('refresh-icon');
            const statusText = document.getElementById('sync-status');
            isSyncPaused = !isSyncPaused;

            if (isSyncPaused) {
                icon.className = 'fa-solid fa-pause text-slate-500';
                statusText.innerText = 'Paused';
                statusText.className = 'text-slate-500';
            } else {
                icon.className = 'fa-solid fa-bolt text-green-500 animate-pulse';
                statusText.innerText = 'Active';
                statusText.className = 'text-green-400';
                currentServerTime = Date.now(); 
            }
        }

        function pauseOnModalOpen() {
            isSyncPaused = true;
            document.getElementById('refresh-icon').className = 'fa-solid fa-pause text-slate-500';
            document.getElementById('sync-status').innerText = 'Paused';
            document.getElementById('sync-status').className = 'text-slate-500';
        }

        function resumeOnModalClose() {
            isSyncPaused = false;
            document.getElementById('refresh-icon').className = 'fa-solid fa-bolt text-green-500 animate-pulse';
            document.getElementById('sync-status').innerText = 'Active';
            document.getElementById('sync-status').className = 'text-green-400';
            currentServerTime = Date.now();
        }

        startSmartSync();

        // --- SIDEBAR TOGGLE ---
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            const arrowIcon = document.getElementById('menu-arrow-icon');
            const toggleBtn = document.getElementById('menu-toggle-btn');
            const isOpen = !sidebar.classList.contains('-translate-x-full');
            if (isOpen) {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.remove('active');
                overlay.classList.add('opacity-0');
                arrowIcon.className = 'fa-solid fa-chevron-right text-lg';
            } else {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.add('active');
                overlay.classList.remove('opacity-0');
                arrowIcon.className = 'fa-solid fa-chevron-left text-lg';
            }
        }

        function showTab(tabId, btn) {
            document.getElementById('dashboard-view').classList.add('hidden-section');
            document.getElementById('settings-view').classList.add('hidden-section');
            document.getElementById('price-view').classList.add('hidden-section');
            
            const selectedTab = document.getElementById(tabId);
            selectedTab.classList.remove('hidden-section');
            selectedTab.classList.remove('fade-in');
            void selectedTab.offsetWidth; 
            selectedTab.classList.add('fade-in');
            
            document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
            btn.classList.add('active');
            const titles = { 
                'dashboard-view': 'Executive Analytics', 
                'settings-view': 'Vault Settings',
                'price-view': 'Market Prices'
            };
            document.getElementById('page-title').innerText = titles[tabId];
            if (window.innerWidth < 1024) {
                toggleSidebar();
            }
        }

        // --- TRANSACTION DETAIL MODAL LOGIC ---
        function openTxModal(index) {
            pauseOnModalOpen();
            const trade = recentTrades[index];
            if(!trade) return;
            document.getElementById('modal-avatar').innerText = trade.username.charAt(0).toUpperCase();
            document.getElementById('modal-username').innerText = trade.username;
            
            let dateStr = "Date Not Available";
            if (trade.closedAt && trade.closedAt._seconds) {
                dateStr = new Date(trade.closedAt._seconds * 1000).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', dateStyle: 'medium', timeStyle: 'short' });
            }
            document.getElementById('modal-date').innerText = dateStr;

            const actionEl = document.getElementById('modal-action');
            if(trade.tradeType === 'Buy') {
                actionEl.innerHTML = `<span class="text-green-400"><i class="fa-solid fa-arrow-down mr-1"></i> BUY</span> <span class="text-slate-400 text-xs sm:text-sm ml-1">via ${trade.networkOrMethod}</span>`;
            } else {
                actionEl.innerHTML = `<span class="text-red-400"><i class="fa-solid fa-arrow-up mr-1"></i> SELL</span> <span class="text-slate-400 text-xs sm:text-sm ml-1">via ${trade.networkOrMethod}</span>`;
            }

            document.getElementById('modal-amount').innerText = '$' + (trade.amountUsd ? trade.amountUsd.toLocaleString() : '0');
            document.getElementById('modal-details').innerText = trade.userReceivingDetails || "No details provided by the user.";
            document.getElementById('modal-closedBy').innerText = trade.closedBy || "Admin";

            const modal = document.getElementById('txModal');
            const content = document.getElementById('txModalContent');
            
            modal.classList.remove('hidden');
            setTimeout(() => {
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeTxModal() {
            resumeOnModalClose();
            const modal = document.getElementById('txModal');
            const content = document.getElementById('txModalContent');
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { modal.classList.add('hidden'); }, 300);
        }

        // --- PENDING KYC MODAL POPUP LOGIC ---
        function openKycModal() {
            pauseOnModalOpen();
            const modal = document.getElementById('kycModal');
            const content = document.getElementById('kycModalContent');
            
            modal.classList.remove('hidden');
            setTimeout(() => {
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeKycModal() {
            resumeOnModalClose();
            const modal = document.getElementById('kycModal');
            const content = document.getElementById('kycModalContent');
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { modal.classList.add('hidden'); }, 300);
        }

        // --- API INTERACTION ---
        async function actionKyc(userId, action) {
            const endpoint = action === 'approve' ? '/api/kyc-approve' : '/api/kyc-reject';
            const confirmationMsg = `Are you sure you want to ${action} this user's KYC verification request?`;
            
            if(!confirm(confirmationMsg)) return;
            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId })
                });
                const result = await response.json();
                if (result.success) {
                    alert(`✅ User KYC successfully ${action}d!`);
                    const row = document.getElementById(`kyc-row-${userId}`);
                    if(row) {
                        row.style.transition = 'all 0.5s ease';
                        row.style.opacity = '0';
                        row.style.transform = 'translateY(15px)';
                        setTimeout(() => {
                            row.remove();
                            const wrapper = document.getElementById('kyc-list-wrapper');
                            if(wrapper && wrapper.children.length === 0) {
                                wrapper.innerHTML = `<div class="text-center py-10 text-slate-500 italic"><i class="fa-solid fa-circle-check text-4xl text-green-500/20 mb-3 block"></i>No pending KYC requests. All clear!</div>`;
                            }
                        }, 500);
                    }
                    setTimeout(() => { window.location.reload(); }, 1000);
                } else {
                    alert(`Error: ${result.error}`);
                }
            } catch (e) { alert("API Connection Error!"); }
        }

        // --- CHARTS LOGIC ---
        const ctxBar = document.getElementById('volumeChart').getContext('2d');
        const gradientLine = ctxBar.createLinearGradient(0, 0, 0, 300);
        gradientLine.addColorStop(0, 'rgba(239, 68, 68, 0.4)'); 
        gradientLine.addColorStop(1, 'rgba(239, 68, 68, 0.0)');
        new Chart(ctxBar, {
            type: 'line', 
            data: {
                labels: ['Daily (24h)', 'Weekly (7d)', 'Monthly (30d)'],
                datasets: [{
                    label: 'Revenue ($)',
                    data: [Number('<%= dailyVol %>'), Number('<%= weeklyVol %>'), Number('<%= monthlyVol %>')],
                    borderColor: '#ef4444', 
                    backgroundColor: gradientLine, 
                    borderWidth: 3, fill: true, tension: 0.4, 
                    pointBackgroundColor: '#0f172a', pointBorderColor: '#ef4444',
                    pointBorderWidth: 2, pointRadius: 5, pointHoverRadius: 7
                }]
            },
            options: { 
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { 
                    y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.03)', drawBorder: false }, ticks: { color: '#64748b', font: { family: 'Outfit', weight: '600' } }, border: { display: false } },
                    x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { family: 'Outfit', weight: '800' } }, border: { display: false } }
                }
            }
        });

        const ctxDoughnut = document.getElementById('ratioChart').getContext('2d');
        const buyV = Number('<%= buyVol %>');
        const sellV = Number('<%= sellVol %>');
        new Chart(ctxDoughnut, {
            type: 'doughnut',
            data: {
                labels: ['Buy (INR in)', 'Sell (Crypto out)'],
                datasets: [{
                    data: [buyV === 0 && sellV === 0 ? 1 : buyV, buyV === 0 && sellV === 0 ? 1 : sellV],
                    backgroundColor: ['#22c55e', '#ef4444'], borderColor: '#0f172a', borderWidth: 5
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '75%',
                plugins: { legend: { position: 'bottom', labels: { color: '#94a3b8', font: { family:'Outfit', weight:'600', size: 12 }, padding: 20 } } }
            }
        });

        const calData = <%- calendarData %>; 

        // --- 📊 NAYA: MONTHLY BAR CHART ---
        const monthlyCtx = document.getElementById('monthlyBarChart').getContext('2d');
        const monthDataRaw = <%- monthWiseData %>;
        
        new Chart(monthlyCtx, {
            type: 'bar',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                datasets: [{
                    label: 'Volume ($)',
                    data: monthDataRaw,
                    backgroundColor: 'rgba(99, 102, 241, 0.5)', 
                    borderColor: 'rgba(99, 102, 241, 1)',
                    borderWidth: 1,
                    borderRadius: 4,
                    hoverBackgroundColor: 'rgba(99, 102, 241, 0.8)'
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)', drawBorder: false }, ticks: { color: '#64748b', font: { family: 'Outfit', weight: '600' } } },
                    x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { family: 'Outfit', weight: '800' } }, border: { display: false } }
                }
            }
        });

        // --- 📊 NAYA: CURRENT WEEK (MON-SUN) MINI CHART ---
        const weeklyCtx = document.getElementById('weeklyBarChart').getContext('2d');
        const currentWeekData = [0, 0, 0, 0, 0, 0, 0];
        
        const todayForWeek = new Date();
        const dayOfWeek = todayForWeek.getDay(); 
        const diffToMonday = todayForWeek.getDate() - dayOfWeek + (dayOfWeek === 0 ? -6 : 1);
        const mondayDate = new Date(todayForWeek.setDate(diffToMonday));

        for (let i = 0; i < 7; i++) {
            const d = new Date(mondayDate);
            d.setDate(mondayDate.getDate() + i);
            const yStr = d.getFullYear();
            const mStr = String(d.getMonth() + 1).padStart(2, '0');
            const dayStr = String(d.getDate()).padStart(2, '0');
            const dateKey = `${yStr}-${mStr}-${dayStr}`;
            currentWeekData[i] = calData[dateKey] || 0;
        }

        new Chart(weeklyCtx, {
            type: 'bar',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    label: 'Volume ($)',
                    data: currentWeekData,
                    backgroundColor: 'rgba(14, 165, 233, 0.4)', 
                    borderColor: 'rgba(14, 165, 233, 0.8)',
                    borderWidth: 1,
                    borderRadius: 4,
                    hoverBackgroundColor: 'rgba(14, 165, 233, 1)'
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { 
                    legend: { display: false },
                    tooltip: { callbacks: { label: function(context) { return '$' + context.raw.toLocaleString(); } } }
                },
                scales: {
                    y: { display: false, beginAtZero: true }, 
                    x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { family: 'Outfit', weight: '700', size: 10 } }, border: { display: false } }
                }
            }
        });

        // --- 📅 ADVANCED TRADING JOURNAL CALENDAR ENGINE ---
        const calendarGridContainer = document.getElementById('calendar-heatmap-grid');
        const monthYearLabel = document.getElementById('calendar-month-year');
        const tooltip = document.getElementById('heatmap-tooltip');
        const tDate = document.getElementById('tooltip-date');
        const tVol = document.getElementById('tooltip-vol');
        
        const todayObj = new Date();
        let currentMonth = todayObj.getMonth();
        let currentYear = todayObj.getFullYear();

        function isSameDay(d1, d2) {
            return d1.getFullYear() === d2.getFullYear() &&
                   d1.getMonth() === d2.getMonth() &&
                   d1.getDate() === d2.getDate();
        }

        window.changeMonth = function(delta) {
            currentMonth += delta;
            if (currentMonth > 11) {
                currentMonth = 0;
                currentYear++;
            } else if (currentMonth < 0) {
                currentMonth = 11;
                currentYear--;
            }
            renderCalendar(currentMonth, currentYear);
        }

        function renderCalendar(month, year) {
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
            monthYearLabel.innerText = `${monthNames[month]} ${year}`;

            const firstDayOfMonth = new Date(year, month, 1).getDay(); 
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const heatmapHTML = [];

            const prevMonthDate = new Date(year, month, 0); 
            const prevMonthDays = prevMonthDate.getDate();
            for (let i = firstDayOfMonth - 1; i >= 0; i--) {
                heatmapHTML.push(`<div class="p-1.5 flex flex-col aspect-square border border-slate-700/50 rounded-md bg-slate-800/40 text-slate-500 opacity-40">
                    <span class="font-bold text-[9px] self-center">${prevMonthDays - i}</span>
                </div>`);
            }
            
            for (let dayNumber = 1; dayNumber <= daysInMonth; dayNumber++) {
                const d = new Date(year, month, dayNumber);
                const dateKey = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
                const vol = calData[dateKey] || 0;

                const todayClass = isSameDay(d, todayObj) ? "border-red-500 shadow-[0_0_10px_rgba(239,68,68,0.3)]" : "";

                let colorClass = "bg-slate-800/60 border-slate-700/50 text-slate-300"; 
                let volTextHTML = "";
                if (vol > 0 && vol <= 500) {
                    colorClass = "bg-emerald-900 border-emerald-800 hover:border-emerald-400 text-slate-300";
                    volTextHTML = `<span class="font-black text-glow-green text-green-400 text-[9px] self-center">$${vol.toLocaleString()}</span>`;
                } else if (vol > 500 && vol <= 2000) {
                    colorClass = "bg-emerald-600 border-emerald-500 hover:border-white text-slate-100";
                    volTextHTML = `<span class="font-black text-glow-green text-green-300 text-[9px] self-center">$${vol.toLocaleString()}</span>`;
                } else if (vol > 2000) {
                    colorClass = "bg-emerald-400 border-emerald-300 shadow-[0_0_8px_rgba(52,211,153,0.5)] hover:border-white text-glow-green text-white";
                    volTextHTML = `<span class="font-black text-glow-green text-green-100 text-[9px] self-center">$${vol.toLocaleString()}</span>`;
                }

                heatmapHTML.push(`<div class="calendar-day p-1.5 flex flex-col justify-between aspect-square border rounded-md transition duration-200 cursor-pointer ${todayClass} ${colorClass}" data-date="${d.toDateString()}" data-vol="$${vol.toLocaleString()}">
                    <span class="font-black text-xs self-center">${dayNumber}</span>
                    ${volTextHTML}
                </div>`);
            }

            const totalCells = heatmapHTML.length;
            const cellsToPad = (7 * (Math.ceil(totalCells / 7))) - totalCells;
            for (let i = 1; i <= cellsToPad; i++) {
                heatmapHTML.push(`<div class="p-1.5 flex flex-col aspect-square border border-slate-700/50 rounded-md bg-slate-800/40 text-slate-500 opacity-40">
                    <span class="font-bold text-[9px] self-center">${i}</span>
                </div>`);
            }
            
            calendarGridContainer.innerHTML = heatmapHTML.join('');

            document.querySelectorAll('.calendar-day').forEach(box => {
                box.addEventListener('mouseenter', (e) => {
                    tDate.innerText = box.getAttribute('data-date');
                    tVol.innerText = 'Volume: ' + box.getAttribute('data-vol');
                    
                    const rect = box.getBoundingClientRect();
                    tooltip.style.left = (rect.left + rect.width / 2) + 'px';
                    tooltip.style.top = (rect.top - 8) + 'px';
                    
                    tooltip.classList.remove('hidden');
                    setTimeout(() => tooltip.classList.remove('opacity-0'), 10);
                });
                box.addEventListener('mouseleave', () => {
                    tooltip.classList.add('opacity-0');
                    setTimeout(() => tooltip.classList.add('hidden'), 200);
                });
            });
        }
        
        renderCalendar(currentMonth, currentYear);

        // --- 🔢 NAYA: NUMBER COUNTER ANIMATION ---
        document.addEventListener("DOMContentLoaded", () => {
            const counters = document.querySelectorAll('.animate-counter');
            
            counters.forEach(counter => {
                const target = +counter.getAttribute('data-target');
                const prefix = counter.getAttribute('data-prefix') || '';
                
                if (target === 0) {
                    counter.innerText = prefix + '0';
                    return;
                }
                
                const duration = 1500; 
                const increment = target / (duration / 16); 
                let current = 0;
                
                const updateCounter = () => {
                    current += increment;
                    if (current < target) {
                        counter.innerText = prefix + Math.ceil(current).toLocaleString();
                        requestAnimationFrame(updateCounter);
                    } else {
                        counter.innerText = prefix + target.toLocaleString();
                    }
                };
                updateCounter();
            });
        });
    </script>
</body>
</html>