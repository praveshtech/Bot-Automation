<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>PropVault — Elite Prop Firm Analytics 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<style>
/* --- ELITE FINANCIAL PSYCHOLOGY COLOR SYSTEM --- */
:root {
  --bg-base: #030712;       
  --bg-surface: rgba(15, 23, 42, 0.65); 
  --bg-surface-light: rgba(30, 41, 59, 0.8);
  --border-dim: rgba(255, 255, 255, 0.04);
  --border-glow: rgba(56, 189, 248, 0.2);
  --accent-gold: #F59E0B;   
  --accent-gold-glow: rgba(245, 158, 11, 0.2);
  --accent-cyan: #38BDF8;   
  --accent-purple: #818CF8; 
  --status-success: #10B981;
  --status-success-dim: rgba(16, 185, 129, 0.1);
  --status-warn: #F59E0B;
  --status-danger: #EF4444;
  --text-main: #F8FAFC;     
  --text-muted: #94A3B8;
  
  --font-head: 'Space Grotesk', sans-serif;
  --font-body: 'Plus Jakarta Sans', sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --radius: 12px;
  --radius-lg: 20px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background-color: var(--bg-base);
  color: var(--text-main);
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.6;
  min-height: 100vh;
  overflow-x: hidden;
  background-image: 
    radial-gradient(circle at 10% 20%, rgba(56, 189, 248, 0.03) 0%, transparent 40%),
    radial-gradient(circle at 90% 80%, rgba(245, 158, 11, 0.03) 0%, transparent 40%);
  background-attachment: fixed;
}

/* --- TEXT & CARD ANIMATIONS --- */
@keyframes glowPulse { 0% { box-shadow: 0 0 10px var(--accent-gold-glow); } 50% { box-shadow: 0 0 25px rgba(245, 158, 11, 0.4); } 100% { box-shadow: 0 0 10px var(--accent-gold-glow); } }
@keyframes textGradient { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
@keyframes slideUpFade { from { opacity: 0; transform: translateY(20px); filter: blur(4px); } to { opacity: 1; transform: translateY(0); filter: blur(0); } }
@keyframes borderFlow { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }

/* --- ORBIT ANIMATIONS --- */
.bg-orbit-container {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 100%; max-width: 1200px; height: 800px;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.orbit-icon {
  position: absolute;
  top: 50%; left: 50%;
  filter: grayscale(100%) opacity(0.12) drop-shadow(0 0 15px rgba(56, 189, 248, 0.4));
}

.orbit-1 { animation: orbitCW1 35s linear infinite; width: 120px; margin-top: -60px; margin-left: -60px; }
.orbit-2 { animation: orbitCCW1 45s linear infinite; width: 100px; margin-top: -50px; margin-left: -50px; }
.orbit-3 { animation: orbitCW2 25s linear infinite; width: 140px; margin-top: -70px; margin-left: -70px; }
.orbit-4 { animation: orbitCCW2 40s linear infinite; width: 110px; margin-top: -55px; margin-left: -55px; }
.orbit-5 { animation: orbitCW3 30s linear infinite; width: 130px; margin-top: -65px; margin-left: -65px; border-radius: 20px; }

@keyframes orbitCW1 {
  0% { transform: rotate(0deg) translateX(350px) rotate(0deg); }
  100% { transform: rotate(360deg) translateX(350px) rotate(-360deg); }
}
@keyframes orbitCCW1 { 
  0% { transform: rotate(360deg) translateX(450px) rotate(-360deg); }
  100% { transform: rotate(0deg) translateX(450px) rotate(0deg); }
}
@keyframes orbitCW2 {
  0% { transform: rotate(120deg) translateX(280px) rotate(-120deg); }
  100% { transform: rotate(480deg) translateX(280px) rotate(-480deg); }
}
@keyframes orbitCCW2 {
  0% { transform: rotate(240deg) translateX(400px) rotate(-240deg); }
  100% { transform: rotate(-120deg) translateX(400px) rotate(120deg); }
}
@keyframes orbitCW3 {
  0% { transform: rotate(70deg) translateX(520px) rotate(-70deg); }
  100% { transform: rotate(430deg) translateX(520px) rotate(-430deg); }
}

.highlight-cyan { color: var(--accent-cyan); font-weight: 600; }
.highlight-gold { color: var(--accent-gold); font-weight: 700; }
.highlight-success { color: var(--status-success); font-weight: 600; }

/* --- NAV --- */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(3, 7, 18, 0.8); backdrop-filter: blur(24px); border-bottom: 1px solid var(--border-dim);
  padding: 0 4%; height: 70px; display: flex; align-items: center; justify-content: space-between;
}
.logo { font-family: var(--font-head); font-weight: 700; font-size: 22px; color: var(--text-main); text-decoration: none; display: flex; align-items: center; gap: 10px; }
.logo-icon { width: 34px; height: 34px; background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple)); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; box-shadow: 0 0 15px rgba(56, 189, 248, 0.3); }
.nav-links { display: flex; gap: 8px; list-style: none; }
.nav-links a { color: var(--text-muted); text-decoration: none; font-size: 14px; font-weight: 600; padding: 8px 16px; border-radius: 8px; transition: all 0.2s; font-family: var(--font-head); text-transform: uppercase; }
.nav-links a:hover { color: var(--text-main); background: rgba(255,255,255,0.03); }
.nav-cta { background: linear-gradient(135deg, var(--accent-gold), #D97706) !important; color: #000 !important; font-weight: 700 !important; box-shadow: 0 4px 15px var(--accent-gold-glow); animation: glowPulse 3s infinite; }

/* --- HERO SECTION --- */
.hero { position: relative; padding: 180px 4% 100px; text-align: center; overflow: hidden; }
.hero-content { position: relative; z-index: 2; }

.hero-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--status-success-dim); border: 1px solid rgba(16, 185, 129, 0.3); color: var(--status-success); font-size: 12px; font-weight: 700; font-family: var(--font-mono); letter-spacing: 1px; text-transform: uppercase; padding: 6px 16px; border-radius: 100px; margin-bottom: 24px; animation: slideUpFade 0.6s ease-out both; }
.hero-badge::before { content: ''; width: 6px; height: 6px; background: var(--status-success); border-radius: 50%; box-shadow: 0 0 8px var(--status-success); }
h1 { font-family: var(--font-head); font-size: clamp(40px, 6vw, 72px); font-weight: 700; line-height: 1.1; letter-spacing: -1.5px; margin-bottom: 24px; animation: slideUpFade 0.8s ease-out 0.1s both; }
.h1-accent { background: linear-gradient(to right, #fff, var(--accent-cyan), var(--accent-purple), #fff); background-size: 300% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent; animation: textGradient 6s linear infinite; }
.hero-sub { color: var(--text-muted); font-size: clamp(16px, 2vw, 19px); max-width: 680px; margin: 0 auto 40px; line-height: 1.7; animation: slideUpFade 1s ease-out 0.2s both; }
.hero-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 70px; animation: slideUpFade 1.2s ease-out 0.3s both; }
.btn-primary { background: linear-gradient(135deg, var(--accent-cyan), #0284c7); color: #000; border: none; padding: 15px 36px; border-radius: 12px; font-family: var(--font-head); font-size: 15px; font-weight: 700; cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); text-decoration: none; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 20px rgba(56, 189, 248, 0.4); }
.btn-primary:hover { transform: translateY(-2px) scale(1.03); box-shadow: 0 8px 30px rgba(56, 189, 248, 0.6); }
.btn-secondary { background: rgba(255,255,255,0.02); color: var(--text-main); border: 1px solid var(--border-dim); padding: 15px 36px; border-radius: 12px; font-family: var(--font-head); font-size: 15px; font-weight: 600; cursor: pointer; transition: all 0.3s; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; backdrop-filter: blur(10px); }
.btn-secondary:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.2); box-shadow: 0 5px 15px rgba(255,255,255,0.05); }

/* --- FILTER BAR --- */
.filter-bar { position: sticky; top: 70px; z-index: 90; background: rgba(3, 7, 18, 0.85); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border-dim); padding: 16px 4%; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
.filter-label { font-family: var(--font-head); font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
.filter-tabs { display: flex; gap: 8px; flex-wrap: wrap; }
.filter-tab { padding: 8px 18px; border-radius: 10px; font-size: 13px; font-weight: 600; cursor: pointer; border: 1px solid var(--border-dim); background: transparent; color: var(--text-muted); transition: all 0.2s; font-family: var(--font-body); }
.filter-tab.active, .filter-tab:hover { background: rgba(56, 189, 248, 0.1); border-color: var(--accent-cyan); color: var(--accent-cyan); box-shadow: 0 0 15px rgba(56, 189, 248, 0.15); }

/* --- SECTION HEADERS --- */
section { padding: 80px 4%; max-width: 1200px; margin: 0 auto; position: relative; z-index: 2; }
.section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 32px; flex-wrap: wrap; gap: 12px; }
.section-title { font-family: var(--font-head); font-size: 26px; font-weight: 700; letter-spacing: -0.5px; }
.section-title span { color: var(--text-muted); font-weight: 400; font-size: 15px; margin-left: 8px; font-family: var(--font-body); }

/* --- ELITE FIRM CARDS --- */
.firms-grid { display: flex; flex-direction: column; gap: 16px; }
.firm-card { background: var(--bg-surface); border: 1px solid var(--border-dim); border-radius: var(--radius-lg); padding: 24px 30px; display: grid; grid-template-columns: 30px 1fr auto auto auto auto; align-items: center; gap: 24px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; text-decoration: none; color: inherit; backdrop-filter: blur(16px); position: relative; overflow: hidden; }
.firm-card:hover { transform: translateY(-4px); border-color: rgba(255,255,255,0.1); box-shadow: 0 20px 40px rgba(0,0,0,0.5), inset 0 0 20px rgba(255, 255, 255, 0.02); }
.firm-card::before { content: ''; position: absolute; bottom: 0; left: 0; height: 2px; width: 0%; background: linear-gradient(90deg, transparent, var(--accent-cyan), transparent); transition: width 0.6s ease; }
.firm-card:hover::before { width: 100%; }
.firm-card::after { content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent); transition: left 0.6s; pointer-events: none; }
.firm-card:hover::after { left: 100%; }

.firm-rank { font-family: var(--font-mono); font-size: 15px; color: var(--text-muted); text-align: center; font-weight: 600; }
.firm-rank.top { color: var(--accent-gold); font-weight: 700; font-size: 18px; text-shadow: 0 0 10px rgba(245, 158, 11, 0.3); }

/* Updated Logo Image Container */
.firm-logo-img { 
  width: 54px; height: 54px; border-radius: 14px; 
  display: flex; align-items: center; justify-content: center; 
  flex-shrink: 0; overflow: hidden; background: #080C14;
  box-shadow: inset 0 0 20px rgba(0,0,0,0.8), 0 0 15px rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
}
.firm-logo-img img { width: 100%; height: 100%; object-fit: contain; padding: 4px; }
.fallback-logo { font-family: var(--font-head); font-weight: 700; font-size: 16px; color: #fff; }

.firm-inner { display: flex; align-items: center; gap: 20px; min-width: 0; }
.firm-name { font-family: var(--font-head); font-weight: 700; font-size: 18px; display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
.firm-tag { font-size: 10px; font-weight: 800; font-family: var(--font-mono); letter-spacing: 1px; text-transform: uppercase; padding: 4px 8px; border-radius: 6px; }
.tag-gold { background: rgba(245, 158, 11, 0.15); color: var(--accent-gold); border: 1px solid rgba(245, 158, 11, 0.4); box-shadow: 0 0 10px rgba(245, 158, 11, 0.2); }
.tag-cyan { background: rgba(56, 189, 248, 0.15); color: var(--accent-cyan); border: 1px solid rgba(56, 189, 248, 0.4); box-shadow: 0 0 10px rgba(56, 189, 248, 0.2); }
.firm-meta { font-size: 13px; color: var(--text-muted); display: flex; align-items: center; gap: 16px; flex-wrap: wrap; font-weight: 500; }
.firm-meta span { display: flex; align-items: center; gap: 4px; }

.trust-score { text-align: center; min-width: 80px; }
.trust-num { font-family: var(--font-head); font-size: 28px; font-weight: 800; letter-spacing: -1px; }
.trust-label { font-size: 11px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-top: -2px;}

.discount-wrap { text-align: center; }
.discount-pill { background: rgba(255,255,255,0.03); border: 1px dashed var(--accent-gold); color: var(--accent-gold); font-family: var(--font-mono); font-size: 15px; font-weight: 700; padding: 8px 18px; border-radius: 10px; letter-spacing: 1px; transition: 0.3s; }
.firm-card:hover .discount-pill { background: rgba(245, 158, 11, 0.05); box-shadow: inset 0 0 10px rgba(245, 158, 11, 0.1); }
.discount-off { font-size: 11px; font-weight: 700; color: var(--accent-gold); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.5px;}

.cashback-chip { background: var(--status-success-dim); border: 1px solid rgba(16, 185, 129, 0.3); color: var(--status-success); font-size: 13px; font-weight: 700; padding: 10px 16px; border-radius: 10px; white-space: nowrap; font-family: var(--font-mono); }
.btn-get { background: rgba(255,255,255,0.05); color: #fff; border: 1px solid var(--border-dim); padding: 12px 28px; border-radius: 10px; font-size: 14px; font-weight: 700; font-family: var(--font-head); cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); white-space: nowrap; }
.firm-card:hover .btn-get { background: var(--accent-cyan); color: #000; border-color: var(--accent-cyan); box-shadow: 0 4px 15px rgba(56, 189, 248, 0.3); }

/* Premium Featured Card */
.firm-card.featured { background: linear-gradient(var(--bg-surface), var(--bg-surface)) padding-box, linear-gradient(135deg, var(--accent-gold), transparent, var(--accent-cyan)) border-box; border: 1px solid transparent; background-size: 200% 200%; animation: borderFlow 5s linear infinite; }
.firm-card.featured:hover { transform: translateY(-4px); box-shadow: 0 25px 50px rgba(0,0,0,0.6), inset 0 0 30px rgba(245, 158, 11, 0.05); }
.firm-card.featured::before { display: none; }
.firm-card.featured::after { content: '★ INSTITUTIONAL PICK'; position: absolute; top: -1px; left: 30px; width: auto; height: auto; background: var(--accent-gold); color: #000; font-size: 10px; font-weight: 800; font-family: var(--font-head); letter-spacing: 1px; padding: 4px 14px; border-radius: 0 0 8px 8px; pointer-events: auto; left: auto; }
.firm-card.featured .firm-inner::after { content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent); transition: left 0.6s; pointer-events: none; }
.firm-card.featured:hover .firm-inner::after { left: 100%; }

/* --- TOAST NOTIFICATION --- */
.toast { position: fixed; bottom: 30px; left: 50%; transform: translate(-50%, 80px); background: rgba(16, 185, 129, 0.95); backdrop-filter: blur(10px); color: #000; padding: 14px 28px; border-radius: 100px; font-size: 14px; font-weight: 700; font-family: var(--font-head); z-index: 999; opacity: 0; transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55); box-shadow: 0 10px 30px rgba(16, 185, 129, 0.4); border: 1px solid rgba(255,255,255,0.2); }
.toast.show { transform: translate(-50%, 0); opacity: 1; }

@media (max-width: 900px) {
  .firm-card { grid-template-columns: 1fr; gap: 16px; text-align: center; }
  .firm-inner { flex-direction: column; text-align: center; }
  .firm-rank { display: none; }
  .firm-meta { justify-content: center; }
  .firm-card.featured::after { left: 50%; transform: translateX(-50%); }
}
</style>
</head>
