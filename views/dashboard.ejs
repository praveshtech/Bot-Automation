<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professor Network | Admin Vault</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gray-900 text-white font-sans p-8">

    <div class="max-w-6xl mx-auto">
        <h1 class="text-4xl font-bold text-red-600 mb-2">🏦 The Vault Dashboard</h1>
        <p class="text-gray-400 mb-8">Live Transaction Monitoring System</p>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-gray-800 p-6 rounded-lg border-l-4 border-blue-500 shadow-lg">
                <h3 class="text-gray-400 text-sm font-bold">LIVE MEMBERS</h3>
                <p class="text-3xl font-bold mt-2">👥 <%= liveMembers %></p>
            </div>
            <div class="bg-gray-800 p-6 rounded-lg border-l-4 border-green-500 shadow-lg">
                <h3 class="text-gray-400 text-sm font-bold">DAILY VOLUME (24h)</h3>
                <p class="text-3xl font-bold text-green-400 mt-2">$<%= dailyVol.toLocaleString() %></p>
            </div>
            <div class="bg-gray-800 p-6 rounded-lg border-l-4 border-yellow-500 shadow-lg">
                <h3 class="text-gray-400 text-sm font-bold">WEEKLY VOLUME (7D)</h3>
                <p class="text-3xl font-bold text-yellow-400 mt-2">$<%= weeklyVol.toLocaleString() %></p>
            </div>
            <div class="bg-gray-800 p-6 rounded-lg border-l-4 border-purple-500 shadow-lg">
                <h3 class="text-gray-400 text-sm font-bold">MONTHLY VOLUME (30D)</h3>
                <p class="text-3xl font-bold text-purple-400 mt-2">$<%= monthlyVol.toLocaleString() %></p>
            </div>
        </div>

        <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
            <h2 class="text-xl font-bold text-gray-300 mb-4">📈 Transaction Volume Overview</h2>
            <canvas id="volumeChart" height="100"></canvas>
        </div>
    </div>

    <script>
        const ctx = document.getElementById('volumeChart').getContext('2d');
        const volumeChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Daily (24h)', 'Weekly (7 Days)', 'Monthly (30 Days)'],
                datasets: [{
                    label: 'Transaction Volume (USD $)',
data: [Number('<%= dailyVol %>'), Number('<%= weeklyVol %>'), Number('<%= monthlyVol %>')],                 
   backgroundColor: [
                        'rgba(34, 197, 94, 0.6)',  // Green
                        'rgba(234, 179, 8, 0.6)',  // Yellow
                        'rgba(168, 85, 247, 0.6)'  // Purple
                    ],
                    borderColor: [
                        'rgba(34, 197, 94, 1)',
                        'rgba(234, 179, 8, 1)',
                        'rgba(168, 85, 247, 1)'
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(255, 255, 255, 0.1)' }, ticks: { color: '#9ca3af' } },
                    x: { grid: { display: false }, ticks: { color: '#9ca3af' } }
                },
                plugins: {
                    legend: { labels: { color: '#fff' } }
                }
            }
        });
    </script>
</body>
</html>