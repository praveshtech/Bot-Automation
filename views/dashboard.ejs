<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Vault | Premium Executive Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Outfit', sans-serif; background-color: #0b1120; background-image: radial-gradient(circle at top right, #1e293b, #0b1120); color: #f8fafc; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #0f172a; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; border: 2px solid #0f172a; }
        ::-webkit-scrollbar-thumb:hover { background: #ef4444; }
        .glass-panel { background: linear-gradient(145deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 1.25rem; box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5); transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease; }
        .glass-panel:hover { border-color: rgba(255, 255, 255, 0.1); transform: translateY(-2px); box-shadow: 0 15px 35px -10px rgba(0, 0, 0, 0.6); }
        .sidebar-link { transition: all 0.3s ease; border-right: 4px solid transparent; }
        .sidebar-link:hover { background: rgba(255, 255, 255, 0.03); transform: translateX(4px); }
        .sidebar-link.active { background: linear-gradient(90deg, rgba(220,38,38,0.0) 0%, rgba(220,38,38,0.15) 100%); border-right: 4px solid #ef4444; color: #ef4444; text-shadow: 0 0 10px rgba(239, 68, 68, 0.3); }
        .text-glow { text-shadow: 0 0 15px rgba(239, 68, 68, 0.6); }
        .text-glow-green { text-shadow: 0 0 15px rgba(34, 197, 94, 0.5); }
        .fade-in { animation: fadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
        @keyframes fadeIn { 0% { opacity: 0; transform: translateY(15px); } 100% { opacity: 1; transform: translateY(0); } }
        .hidden-section { display: none; }
        tbody tr { transition: all 0.2s ease; }
        tbody tr:hover { background: rgba(239, 68, 68, 0.1) !important; transform: scale(1.01); }
        #sidebar-overlay { transition: opacity 0.3s ease; pointer-events: none; }
        #sidebar-overlay.active { opacity: 1; pointer-events: auto; }
        .custom-scrollbar::-webkit-scrollbar { height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: rgba(15, 23, 42, 0.5); border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(52, 211, 153, 0.3); border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(52, 211, 153, 0.6); }
        input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.8) sepia(1) saturate(5) hue-rotate(220deg); cursor: pointer; }
    </style>
</head>
<body class="min-h-screen flex overflow-x-hidden">

    <div id="sidebar-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 opacity-0 lg:hidden" onclick="toggleSidebar()"></div>

    <aside id="sidebar" class="w-64 bg-slate-900/95 border-r border-slate-800/50 flex flex-col fixed h-full z-50 shadow-[5px_0_30px_rgba(0,0,0,0.5)] backdrop-blur-xl transition-all duration-300 transform -translate-x-full lg:translate-x-0">
        <div class="p-8 relative">
            <h1 class="text-3xl font-black uppercase tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-red-700 flex items-center text-glow"><i class="fa-solid fa-building-columns mr-3 text-red-600"></i> Vault</h1>
            <div class="mt-2 text-[10px] uppercase tracking-[0.3em] text-slate-500 font-bold ml-10">Admin Control</div>
            <button onclick="toggleSidebar()" class="lg:hidden absolute top-8 right-6 text-slate-400 hover:text-red-500 transition duration-300"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>

        <nav class="flex-1 mt-6 px-4 space-y-3">
            <button onclick="showTab('dashboard-view', this)" class="sidebar-link active w-full flex items-center px-5 py-3.5 text-sm font-bold uppercase tracking-widest text-slate-400 rounded-lg"><i class="fa-solid fa-chart-line mr-4 text-lg"></i> Dashboard</button>
            <button onclick="showTab('price-view', this)" class="sidebar-link w-full flex items-center px-5 py-3.5 text-sm font-bold uppercase tracking-widest text-slate-400 rounded-lg"><i class="fa-solid fa-money-bill-trend-up mr-4 text-lg"></i> Price Update</button>
            <button onclick="showTab('settings-view', this)" class="sidebar-link w-full flex items-center px-5 py-3.5 text-sm font-bold uppercase tracking-widest text-slate-400 rounded-lg"><i class="fa-solid fa-shield-halved mr-4 text-lg"></i> Settings</button>
            <button onclick="showTab('kyc-view', this)" class="sidebar-link w-full flex items-center px-5 py-3.5 text-sm font-bold uppercase tracking-widest text-slate-400 rounded-lg"><i class="fa-solid fa-address-card mr-4 text-lg"></i> User KYC</button>
            <button onclick="showTab('wallet-view', this)" class="sidebar-link w-full flex items-center px-5 py-3.5 text-sm font-bold uppercase tracking-widest text-slate-400 rounded-lg"><i class="fa-solid fa-wallet mr-4 text-lg"></i> Wallet Addresses</button>
            <button onclick="showTab('logs-view', this)" class="sidebar-link w-full flex items-center px-5 py-3.5 text-sm font-bold uppercase tracking-widest text-slate-400 rounded-lg"><i class="fa-solid fa-list-check mr-4 text-lg"></i> Transaction Logs</button>
        </nav>

        <div class="p-6 border-t border-slate-800/50">
            <button onclick="confirmLogout()" class="w-full flex items-center justify-center px-4 py-3 text-sm font-bold uppercase tracking-widest text-red-400 hover:text-white bg-red-950/30 hover:bg-red-600/80 rounded-xl transition-all duration-300 shadow-[0_0_10px_rgba(220,38,38,0.1)] hover:shadow-[0_0_15px_rgba(220,38,38,0.4)] border border-red-900/50">
                <i class="fa-solid fa-power-off mr-3"></i> Lock Vault
            </button>
        </div>
    </aside>

    <main class="flex-1 w-full lg:ml-64 p-4 sm:p-6 md:p-10 min-h-screen">
        <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4 fade-in">
            <div class="flex items-center gap-4">
                <button id="menu-toggle-btn" onclick="toggleSidebar()" class="lg:hidden w-11 h-11 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-red-500 shadow-[0_0_15px_rgba(239,68,68,0.2)] hover:bg-slate-700 transition duration-300"><i id="menu-arrow-icon" class="fa-solid fa-chevron-right text-lg"></i></button>
                <div>
                    <h2 id="page-title" class="text-2xl sm:text-3xl font-black text-gray-100 tracking-tight">Executive Analytics</h2>
                    <p class="text-slate-400 text-xs sm:text-sm font-medium mt-1">Real-time Professor Network Monitoring</p>
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-3 w-full sm:w-auto">
                <div class="glass-panel px-4 py-2 flex items-center space-x-3 border-slate-700/50 text-xs font-bold uppercase tracking-wider">
                    <div class="flex items-center space-x-2">
                        <button onclick="toggleSmartSync()" id="refresh-toggle-btn" class="text-green-500 hover:text-green-400 transition"><i id="refresh-icon" class="fa-solid fa-bolt animate-pulse"></i></button>
                        <span>Smart Sync: <span id="sync-status" class="text-green-400">Active</span></span>
                    </div>
                </div>
                <a href="/export-ledger" class="glass-panel justify-center px-4 py-2.5 text-emerald-400 hover:text-emerald-300 border-emerald-500/20 hover:border-emerald-500/50 transition flex items-center text-xs font-bold uppercase tracking-widest shadow-[0_0_15px_rgba(16,185,129,0.1)]"><i class="fa-solid fa-file-excel mr-2 text-base"></i> Export</a>
                <div class="glass-panel px-4 py-2.5 flex items-center justify-center space-x-3 border-slate-700/50">
                    <div class="w-2.5 h-2.5 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_#22c55e]"></div>
                    <span class="text-xs font-black uppercase tracking-widest text-slate-300">Live DB</span>
                </div>
            </div>
        </header>

        <section id="dashboard-view" class="fade-in">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="glass-panel p-6 border-l-4 border-blue-500">
                    <div class="flex justify-between items-start">
                        <h3 class="text-slate-400 text-xs font-bold uppercase tracking-widest">Network Strength</h3>
                        <i class="fa-solid fa-users text-blue-500/50"></i>
                    </div>
                    <p class="text-3xl sm:text-4xl font-black mt-3 text-white animate-counter" data-target="<%= liveMembers %>" data-prefix="">0</p>
                </div>
                <div class="glass-panel p-6 border-l-4 border-green-500">
                    <div class="flex justify-between items-start">
                        <h3 class="text-slate-400 text-xs font-bold uppercase tracking-widest">Daily Vol (24h)</h3>
                        <i class="fa-solid fa-chart-bar text-green-500/50"></i>
                    </div>
                    <p class="text-3xl sm:text-4xl font-black mt-3 text-green-400 text-glow-green animate-counter" data-target="<%= dailyVol %>" data-prefix="$">0</p>
                </div>
                <div onclick="openCustomVolModal()" class="glass-panel p-6 border-l-4 border-purple-500 hover:border-purple-400 transition-colors duration-300 cursor-pointer group">
                    <div class="flex justify-between items-start">
                        <div class="flex flex-col">
                            <h3 class="text-slate-400 text-xs font-bold uppercase tracking-widest">Monthly Vol (30d)</h3>
                            <span class="text-[10px] text-purple-500/60 font-black tracking-widest mt-0.5 group-hover:text-purple-400 transition"><i class="fa-solid fa-calendar-alt"></i> Click for Custom Date</span>
                        </div>
                        <i class="fa-solid fa-sack-dollar text-purple-500/50 text-lg group-hover:text-purple-400 transition"></i>
                    </div>
                    <p class="text-3xl sm:text-4xl font-black mt-3 text-purple-400 drop-shadow-[0_0_15px_rgba(168,85,247,0.5)] animate-counter" data-target="<%= monthlyVol %>" data-prefix="$">0</p>
                </div>
                <div class="glass-panel p-6 border-l-4 border-yellow-500 hover:border-yellow-400 transition-colors duration-300">
                    <div class="flex justify-between items-start">
                        <h3 class="text-slate-400 text-xs font-bold uppercase tracking-widest">Non-KYC Revenue</h3>
                        <i class="fa-solid fa-hand-holding-dollar text-yellow-500/50 text-lg"></i>
                    </div>
                    <% 
                       // 🔥 Dashboard ke liye total fee revenue calculate kar rahe hain
                       const totalNonKycRev = (typeof allLogs !== 'undefined' ? allLogs : [])
                           .filter(t => t.isVerifiedTrade !== true)
                           .reduce((sum, trade) => sum + (trade.fee || 0), 0);
                    %>
                    <p class="text-3xl sm:text-4xl font-black mt-3 text-yellow-400 drop-shadow-[0_0_15px_rgba(234,179,8,0.5)] animate-counter" data-target="<%= totalNonKycRev %>" data-prefix="$">0</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
                <div class="glass-panel p-4 sm:p-6 lg:col-span-2">
                    <div class="flex items-center mb-6">
                        <div class="p-2 bg-blue-500/10 rounded-lg mr-3"><i class="fa-solid fa-chart-area text-blue-400"></i></div>
                        <h4 class="font-black uppercase text-sm text-slate-300 tracking-wider">Revenue Trajectory</h4>
                    </div>
                    <div class="h-64 sm:h-72"><canvas id="volumeChart"></canvas></div>
                </div>
                <div class="glass-panel p-4 sm:p-6 flex flex-col items-center relative overflow-hidden">
                    <div class="w-full flex items-center mb-4 relative z-10">
                        <div class="p-2 bg-purple-500/10 rounded-lg mr-3"><i class="fa-solid fa-scale-balanced text-purple-400"></i></div>
                        <h4 class="font-black uppercase text-sm text-slate-300 tracking-wider">Buy vs Sell Ratio</h4>
                    </div>
                    <div class="relative h-56 sm:h-60 w-full flex justify-center z-10"><canvas id="ratioChart"></canvas></div>
                    <i class="fa-solid fa-chart-pie absolute -right-10 -bottom-10 text-9xl text-slate-800/30 z-0"></i>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8 fade-in">
                <div class="glass-panel p-4 sm:p-6 relative overflow-hidden flex flex-col h-full">
                    <div class="flex-1 flex flex-col">
                        <div class="flex items-center mb-4 relative z-10">
                            <div class="p-2 bg-indigo-500/10 rounded-lg mr-3"><i class="fa-solid fa-chart-column text-indigo-400"></i></div>
                            <h4 class="font-black uppercase text-sm text-slate-300 tracking-wider">Monthly Volume</h4>
                        </div>
                        <div class="relative flex-1 min-h-[160px] w-full z-10"><canvas id="monthlyBarChart"></canvas></div>
                    </div>
                    <div class="mt-6 pt-5 border-t border-slate-700/50 shrink-0">
                        <div class="flex items-center mb-3 relative z-10">
                            <div class="p-1.5 bg-sky-500/10 rounded-lg mr-3"><i class="fa-solid fa-calendar-week text-sky-400 text-xs"></i></div>
                            <h4 class="font-black uppercase text-xs text-slate-400 tracking-widest">Current Week (Mon-Sun)</h4>
                        </div>
                        <div class="relative h-32 z-10 w-full"><canvas id="weeklyBarChart"></canvas></div>
                    </div>
                </div>

                <div class="glass-panel p-4 sm:p-6 relative overflow-hidden">
                    <div class="flex items-center mb-6 relative z-10">
                        <div class="p-2 bg-emerald-500/10 rounded-lg mr-3"><i class="fa-solid fa-calendar-days text-emerald-400"></i></div>
                        <h4 class="font-black uppercase text-sm text-slate-300 tracking-wider">Trading Activity</h4>
                    </div>
                    <div class="flex items-center justify-between mb-5 relative z-10 text-slate-100">
                        <button onclick="changeMonth(-1)" class="w-8 h-8 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-red-500 shadow-[0_0_15px_rgba(239,68,68,0.2)] hover:bg-slate-700 transition duration-300"><i class="fa-solid fa-chevron-left"></i></button>
                        <div id="calendar-month-year" class="font-black text-lg tracking-tight"></div>
                        <button onclick="changeMonth(1)" class="w-8 h-8 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-red-500 shadow-[0_0_15px_rgba(239,68,68,0.2)] hover:bg-slate-700 transition duration-300"><i class="fa-solid fa-chevron-right"></i></button>
                    </div>
                    <div class="relative z-10 pb-4 overflow-x-auto overflow-y-hidden custom-scrollbar">
                        <div class="grid grid-cols-7 text-center text-[10px] text-slate-500 font-bold mb-3 pl-1 whitespace-nowrap"><span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span></div>
                        <div id="calendar-heatmap-grid" class="grid grid-cols-7 grid-flow-row gap-[5px] sm:gap-[6px] h-auto"></div>
                    </div>
                    <div class="mt-2 pt-3 border-t border-slate-700/50 flex justify-end items-center text-[10px] text-slate-400 uppercase font-bold gap-2 relative z-10">
                        <span>Less</span><div class="w-3 h-3 rounded-[2px] bg-slate-800/80 border border-slate-700"></div><div class="w-3 h-3 rounded-[2px] bg-emerald-900 border border-emerald-800"></div><div class="w-3 h-3 rounded-[2px] bg-emerald-600 border border-emerald-500"></div><div class="w-3 h-3 rounded-[2px] bg-emerald-400 border border-emerald-300 shadow-[0_0_8px_rgba(52,211,153,0.5)]"></div><span>More</span>
                    </div>
                    <div id="heatmap-tooltip" class="fixed hidden bg-slate-900/95 backdrop-blur-md border border-slate-700 text-white text-xs font-bold px-3 py-2 rounded-lg shadow-2xl z-50 pointer-events-none transform -translate-x-1/2 -translate-y-full mt-[-10px] whitespace-nowrap transition-opacity duration-200 opacity-0">
                        <span id="tooltip-date" class="text-slate-400 block text-[9px] uppercase tracking-widest mb-1"></span>
                        <span id="tooltip-vol" class="text-green-400 font-black text-sm"></span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 pb-10">
                <div class="glass-panel p-0 lg:col-span-2 overflow-hidden">
                    <div class="p-6 border-b border-slate-700/50 flex items-center justify-between">
                        <div class="flex items-center"><div class="p-2 bg-red-500/10 rounded-lg mr-3"><i class="fa-solid fa-bolt text-red-400"></i></div><h4 class="font-black uppercase text-sm text-slate-300 tracking-wider">Live Feed</h4></div>
                        <span class="text-[9px] sm:text-[10px] text-slate-500 font-bold uppercase tracking-widest"><i class="fa-solid fa-hand-pointer mr-1"></i> Tap to view</span>
                    </div>
                    <div class="overflow-x-auto w-full">
                        <table class="w-full text-left whitespace-nowrap min-w-[500px] lg:min-w-0">
                            <thead class="bg-slate-800/30">
                                <tr class="text-slate-400 text-xs font-bold uppercase tracking-widest"><th class="py-4 px-6">User</th><th class="py-4 px-6">Action</th><th class="py-4 px-6">Method</th><th class="py-4 px-6 text-right">Amount (USD)</th></tr>
                            </thead>
                            <tbody class="text-sm font-medium">
                                <% if (recentFeed.length === 0) { %>
                                     <tr><td colspan="4" class="text-center py-8 text-slate-500 italic">No recent transactions</td></tr>
                                <% } else { %>
                                    <% recentFeed.forEach((trade, index) => { %>
                                        <tr class="border-b border-slate-800/50 cursor-pointer group" onclick="openTxModal(<%= index %>)">
                                            <td class="py-4 px-6 text-gray-200 flex items-center group-hover:text-white transition"><div class="w-8 h-8 rounded-full bg-slate-700 flex justify-center items-center mr-3 text-xs font-black text-slate-400 group-hover:bg-red-600 group-hover:text-white transition"><%= trade.username.charAt(0).toUpperCase() %></div><%= trade.username %></td>
                                            <td class="py-4 px-6"><% if (trade.tradeType === 'Buy') { %><span class="bg-green-500/10 border border-green-500/20 text-green-400 px-3 py-1.5 rounded-md text-xs font-black tracking-wider"><i class="fa-solid fa-arrow-down mr-1"></i> BUY</span><% } else { %><span class="bg-red-500/10 border border-red-500/20 text-red-400 px-3 py-1.5 rounded-md text-xs font-black tracking-wider"><i class="fa-solid fa-arrow-up mr-1"></i> SELL</span><% } %></td>
                                            <td class="py-4 px-6 text-slate-400"><%= trade.networkOrMethod %></td>
                                            <td class="py-4 px-6 text-right font-black text-gray-100 text-base group-hover:text-red-400 transition">$<%= trade.amountUsd.toLocaleString() %></td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="glass-panel p-6">
                    <div class="flex items-center mb-6"><div class="p-2 bg-yellow-500/10 rounded-lg mr-3"><i class="fa-solid fa-crown text-yellow-400"></i></div><h4 class="font-black uppercase text-sm text-slate-300 tracking-wider">Top Whales</h4></div>
                    <div class="space-y-3">
                        <% if (topTraders.length === 0) { %><p class="text-slate-500 italic text-center text-sm py-4">Awaiting volume...</p><% } %>
                        <% topTraders.forEach((trader, index) => { %>
                            <div class="flex justify-between items-center p-4 bg-slate-800/40 hover:bg-slate-700/50 rounded-xl border border-white/5 transition duration-300 group">
                                <div class="flex items-center space-x-3">
                                    <% if (index === 0) { %><div class="w-7 h-7 rounded-full bg-gradient-to-br from-yellow-300 to-yellow-600 flex items-center justify-center font-black text-black shadow-[0_0_10px_rgba(234,179,8,0.5)] text-xs">1</div>
                                    <% } else if (index === 1) { %><div class="w-7 h-7 rounded-full bg-gradient-to-br from-gray-300 to-gray-500 flex items-center justify-center font-black text-black text-xs">2</div>
                                    <% } else if (index === 2) { %><div class="w-7 h-7 rounded-full bg-gradient-to-br from-orange-400 to-orange-700 flex items-center justify-center font-black text-white text-xs">3</div>
                                    <% } else { %><div class="w-7 h-7 rounded-full bg-slate-700 flex items-center justify-center font-bold text-gray-400 text-xs"><%= index + 1 %></div><% } %>
                                    <span class="font-bold text-slate-300 group-hover:text-white transition"><%= trader.username %></span>
                                </div>
                                <span class="font-black text-green-400 bg-green-500/10 px-2 py-1 rounded text-sm">$<%= trader.totalVolume.toLocaleString() %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </section>

        <section id="kyc-view" class="hidden-section fade-in">
            <div class="glass-panel p-6 border-t-4 border-blue-500 relative overflow-hidden">
                <h3 class="text-xl sm:text-2xl font-black uppercase tracking-widest mb-6 text-blue-500 text-glow"><i class="fa-solid fa-users mr-2"></i> Vault Verified Users Database</h3>
                <div class="overflow-x-auto w-full custom-scrollbar">
                    <table class="w-full text-left whitespace-nowrap">
                        <thead class="bg-slate-800/30">
                            <tr class="text-slate-400 text-xs font-bold uppercase tracking-widest border-b border-slate-700/50"><th class="py-4 px-6">User Details</th><th class="py-4 px-6">Name</th><th class="py-4 px-6">Status</th><th class="py-4 px-6 text-right">Actions</th></tr>
                        </thead>
                        <tbody class="text-sm font-medium">
                            <% allKycUsers.forEach(user => { %>
                            <tr class="border-b border-slate-800/50 hover:bg-slate-800/30 transition cursor-pointer" onclick="openUserModal('<%= user.id %>')">
                                <td class="py-4 px-6 text-gray-200">
                                    <div class="font-bold text-base"><%= user.discordContact || user.username %></div><div class="text-[10px] text-slate-500 uppercase tracking-widest">ID: <%= user.discordId %></div>
                                </td>
                                <td class="py-4 px-6 text-slate-300"><%= user.name || 'N/A' %></td>
                                <td class="py-4 px-6"><span class="px-3 py-1.5 rounded-md text-[10px] font-black tracking-widest uppercase <%= user.status === 'Approved' ? 'bg-green-500/10 text-green-400 border border-green-500/20' : (user.status === 'Rejected' ? 'bg-red-500/10 text-red-400 border border-red-500/20' : 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20') %>"><%= user.status %></span></td>
                                <td class="py-4 px-6 text-right">
                                    <div class="flex items-center justify-end space-x-3">
                                        <% if((user.photos && user.photos.length > 0) || user.idPhoto) { %>
