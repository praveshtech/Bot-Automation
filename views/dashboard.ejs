        <section id="logs-view" class="hidden-section fade-in">
            <div class="glass-panel p-6 border-t-4 border-indigo-500 relative overflow-hidden">
                <h3 class="text-xl sm:text-2xl font-black uppercase tracking-widest mb-6 text-indigo-500 text-glow"><i class="fa-solid fa-list-check mr-2"></i> Vault Transaction Logs</h3>
                
              <% 
                   const kycLogs = (typeof allLogs !== 'undefined' ? allLogs : []).filter(t => t.isVerifiedTrade === true);
                   const nonKycLogs = (typeof allLogs !== 'undefined' ? allLogs : []).filter(t => t.isVerifiedTrade !== true);
                   
                   // Volume ka sum
                   const kycTotalVolume = kycLogs.reduce((sum, trade) => sum + (trade.amountUsd || 0), 0);
                   const nonKycTotalVolume = nonKycLogs.reduce((sum, trade) => sum + (trade.amountUsd || 0), 0);

                   // 🔥 NAYA CODE: Fee Revenue ka sum (Ab sirf Non-KYC ke liye use hoga)
                   const nonKycTotalFee = nonKycLogs.reduce((sum, trade) => sum + (trade.fee || 0), 0);
                %>

                <!-- TABS & STATS HEADER -->
                <div class="flex flex-wrap justify-between items-end mb-6 border-b border-slate-700/50 pb-2 gap-4">
                    <div class="flex space-x-6">
                        <button onclick="switchLogTab('kyc-logs')" id="btn-kyc-logs" class="text-green-400 font-black uppercase tracking-widest border-b-2 border-green-500 pb-2 px-2 transition duration-300">🛡️ KYC Trades</button>
                        <button onclick="switchLogTab('non-kyc-logs')" id="btn-non-kyc-logs" class="text-slate-500 hover:text-slate-300 font-bold uppercase tracking-widest pb-2 px-2 transition duration-300">⚠️ Non-KYC Trades</button>
                    </div>
                    
                    <!-- KYC STATS -->
                    <div id="kyc-stats" class="text-[10px] sm:text-xs font-black uppercase tracking-widest text-slate-400 pb-1 flex flex-wrap gap-2">
                        <span class="bg-slate-800/50 px-3 py-1.5 rounded-md border border-slate-700/50">Total Trades: <span class="text-white ml-1"><%= kycLogs.length %></span></span>
                        <span class="bg-green-900/20 px-3 py-1.5 rounded-md border border-green-500/30">Volume: <span class="text-green-400 ml-1">$<%= kycTotalVolume.toLocaleString() %></span></span>
                    </div>
                    
                    <!-- NON-KYC STATS -->
                    <div id="non-kyc-stats" class="hidden text-[10px] sm:text-xs font-black uppercase tracking-widest text-slate-400 pb-1 flex flex-wrap gap-2">
                        <span class="bg-slate-800/50 px-3 py-1.5 rounded-md border border-slate-700/50">Total Trades: <span class="text-white ml-1"><%= nonKycLogs.length %></span></span>
                        <span class="bg-orange-900/20 px-3 py-1.5 rounded-md border border-orange-500/30">Volume: <span class="text-orange-400 ml-1">$<%= nonKycTotalVolume.toLocaleString() %></span></span>
                        <!-- 🔥 BADGE: Total Fee Revenue (Amount ab Yellow aayega) -->
                        <span class="bg-blue-900/20 px-3 py-1.5 rounded-md border border-blue-500/30">Fee Rev: <span class="text-yellow-400 ml-1">$<%= nonKycTotalFee.toLocaleString() %></span></span>
                    </div>
                </div>
                <!-- KYC TRADES TABLE -->
                <div id="kyc-logs" class="overflow-x-auto w-full custom-scrollbar">
                    <table class="w-full text-left whitespace-nowrap">
                        <thead class="bg-slate-800/30">
                            <tr class="text-slate-400 text-xs font-bold uppercase tracking-widest"><th class="py-4 px-6">Date</th><th class="py-4 px-6">User</th><th class="py-4 px-6">Action</th><th class="py-4 px-6">Method</th><th class="py-4 px-6 text-right">Amount (USD)</th></tr>
                        </thead>
                        <tbody class="text-sm font-medium">
                            <% if (kycLogs.length === 0) { %>
                                 <tr><td colspan="5" class="text-center py-8 text-slate-500 italic">No KYC transactions found.</td></tr>
                            <% } else { %>
                                <% kycLogs.forEach((trade) => { %>
                                    <tr class="border-b border-slate-800/50 hover:bg-slate-800/30 transition">
                                        <td class="py-4 px-6 text-slate-400 text-xs"><%= (trade.closedAt && trade.closedAt._seconds) ? new Date(trade.closedAt._seconds * 1000).toLocaleString('en-IN') : 'N/A' %></td>
                                        <td class="py-4 px-6 text-gray-200"><div class="font-bold"><%= trade.username %></div></td>
                                        <td class="py-4 px-6"><% if (trade.tradeType === 'Buy') { %><span class="text-green-400 font-black text-xs tracking-wider">BUY</span><% } else { %><span class="text-red-400 font-black text-xs tracking-wider">SELL</span><% } %></td>
                                        <td class="py-4 px-6 text-slate-400"><%= trade.networkOrMethod %></td>
                                        <td class="py-4 px-6 text-right font-black text-green-400">$<%= trade.amountUsd.toLocaleString() %></td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- NON-KYC TRADES TABLE -->
                <div id="non-kyc-logs" class="hidden overflow-x-auto w-full custom-scrollbar">
                    <table class="w-full text-left whitespace-nowrap">
                        <thead class="bg-slate-800/30">
                            <tr class="text-slate-400 text-xs font-bold uppercase tracking-widest"><th class="py-4 px-6">Date</th><th class="py-4 px-6">User</th><th class="py-4 px-6">Action</th><th class="py-4 px-6">Method</th><th class="py-4 px-6 text-right">Amount (USD)</th></tr>
                        </thead>
                        <tbody class="text-sm font-medium">
                            <% if (nonKycLogs.length === 0) { %>
                                 <tr><td colspan="5" class="text-center py-8 text-slate-500 italic">No Non-KYC transactions found.</td></tr>
                            <% } else { %>
                                <% nonKycLogs.forEach((trade) => { %>
                                    <tr class="border-b border-slate-800/50 hover:bg-slate-800/30 transition">
                                        <td class="py-4 px-6 text-slate-400 text-xs"><%= (trade.closedAt && trade.closedAt._seconds) ? new Date(trade.closedAt._seconds * 1000).toLocaleString('en-IN') : 'N/A' %></td>
                                        <td class="py-4 px-6 text-gray-200"><div class="font-bold"><%= trade.username %></div></td>
                                        <td class="py-4 px-6"><% if (trade.tradeType === 'Buy') { %><span class="text-green-400 font-black text-xs tracking-wider">BUY</span><% } else { %><span class="text-red-400 font-black text-xs tracking-wider">SELL</span><% } %></td>
                                        <td class="py-4 px-6 text-slate-400"><%= trade.networkOrMethod %></td>
                                        <td class="py-4 px-6 text-right font-black text-orange-400">$<%= trade.amountUsd.toLocaleString() %></td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

    </main>

    <!-- CUSTOM DATE VOLUME MODAL -->
