            </div>
            <div>
                <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-2 flex items-center"><i class="fa-solid fa-file-invoice mr-2"></i> User Provided Details</p>
                <div class="bg-[#050b14] p-4 sm:p-5 rounded-xl border border-slate-700 text-xs sm:text-sm font-medium text-green-400 whitespace-pre-wrap font-mono shadow-inner max-h-40 overflow-y-auto" id="modal-details">Loading...</div>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-700/50 flex justify-between items-center text-[10px] text-slate-500 font-bold uppercase"><span>Closed By: <span id="modal-closedBy" class="text-slate-300">Admin</span></span><span class="text-red-500"><i class="fa-solid fa-shield-check mr-1"></i> Vault Secured</span></div>
        </div>
    </div>

    <div id="kycModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 overflow-y-auto">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity" onclick="closeKycModal()"></div>
        <div class="glass-panel relative z-10 w-full max-w-2xl p-5 sm:p-8 border-t-4 border-yellow-500 transform scale-95 opacity-0 transition-all duration-300" id="kycModalContent">
            <button onclick="closeKycModal()" class="absolute top-5 right-5 text-slate-400 hover:text-yellow-500 transition duration-300 bg-slate-800/50 hover:bg-slate-800 w-8 h-8 rounded-full flex items-center justify-center"><i class="fa-solid fa-xmark text-lg"></i></button>
            <div class="mb-6 border-b border-slate-700/50 pb-4">
                <h3 class="text-xl sm:text-2xl font-black text-white tracking-tight flex items-center"><i class="fa-solid fa-user-shield text-yellow-500 mr-3"></i> Pending KYC Reviews</h3>
                <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mt-1">Review and action the verification requests.</p>
            </div>
            <div class="space-y-4 max-h-[350px] sm:max-h-[400px] overflow-y-auto pr-1" id="kyc-list-wrapper">
                <% if (pendingKycList.length === 0) { %>
                    <div class="text-center py-10 text-slate-500 italic"><i class="fa-solid fa-circle-check text-4xl text-green-500/20 mb-3 block"></i>No pending KYC requests. All clear!</div>
                <% } else { %>
                    <% pendingKycList.forEach(kyc => { %>
                        <div class="bg-slate-900/60 p-4 sm:p-5 rounded-xl border border-slate-800 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 transition duration-300 hover:border-slate-700" id="kyc-row-<%= kyc.discordId %>">
                            <div class="flex-1 w-full">
                                <div class="flex items-center space-x-3 mb-2"><span class="bg-yellow-500/10 text-yellow-400 text-[9px] font-black px-2 py-0.5 rounded uppercase tracking-wider">Pending</span><span class="text-xs font-black text-slate-400">ID: <%= kyc.discordContact %></span></div>
                                <h4 class="font-bold text-white text-sm sm:text-base">Alias: <span class="text-yellow-400"><%= kyc.name %></span></h4><p class="text-xs text-slate-400 mt-1">Tag: @<%= kyc.username %></p>
                                <div class="bg-[#050b14]/50 border border-slate-800/80 p-2.5 rounded-lg mt-3 text-xs text-slate-300 font-mono overflow-x-auto"><span class="text-slate-500 font-bold block mb-1">Details:</span><%= kyc.paymentInfo %></div>
                            </div>
                            <div class="flex md:flex-col gap-2 w-full md:w-auto">
                                <button onclick="actionKyc('<%= kyc.discordId %>', 'approve')" class="flex-1 md:flex-initial w-full md:w-28 bg-green-600 hover:bg-green-700 text-white text-xs font-black uppercase tracking-wider py-2.5 rounded-lg transition-all shadow-[0_0_10px_rgba(34,197,94,0.1)]">Approve</button>
                                <button onclick="actionKyc('<%= kyc.discordId %>', 'reject')" class="flex-1 md:flex-initial w-full md:w-28 bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white text-xs font-black uppercase tracking-wider py-2.5 rounded-lg border border-red-500/10 transition-all">Reject</button>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-700/50 text-right text-[10px] text-slate-500 font-black uppercase tracking-widest"><i class="fa-solid fa-clock-rotate-left mr-1"></i> Waiting Queue: <%= pendingKyc %></div>
        </div>
    </div>

    <script>
        const recentTrades = <%- JSON.stringify(recentFeed || []) %>;
        const allKycData = <%- JSON.stringify(allKycUsers || []).replace(/</g, '\\u003c') %>;
        const allLogsDataClient = <%- JSON.stringify(typeof allLogs !== 'undefined' ? allLogs : []).replace(/</g, '\\u003c') %>;
    </script>

    <script>
        // --- 🚀 MODERN ALERT SETUP ---
        const VaultAlert = Swal.mixin({
            background: '#0f172a', color: '#f8fafc',
            customClass: { popup: 'border border-slate-700 rounded-2xl shadow-[0_0_30px_rgba(0,0,0,0.8)]', confirmButton: 'font-black uppercase tracking-widest px-6 py-2.5 rounded-lg', cancelButton: 'font-bold uppercase tracking-widest px-6 py-2.5 rounded-lg' }
        });

        function confirmLogout() {
            VaultAlert.fire({
                title: 'Lock Vault?', text: 'Are you sure you want to securely lock the system and logout?', icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#334155', confirmButtonText: '<i class="fa-solid fa-lock mr-2"></i> Yes, Lock It!'
            }).then((result) => { if (result.isConfirmed) { window.location.href = '/logout'; } });
        }

        async function actionKyc(userId, action) {
            const actionText = action === 'approve' ? 'Approve' : 'Reject';
            const btnColor = action === 'approve' ? '#22c55e' : '#ef4444';
            const result = await VaultAlert.fire({ title: `${actionText} KYC?`, text: `Are you sure you want to ${action} this user's verification?`, icon: 'question', showCancelButton: true, confirmButtonColor: btnColor, cancelButtonColor: '#334155', confirmButtonText: `Yes, ${actionText}` });
            if(!result.isConfirmed) return;

            try {
                const response = await fetch(action === 'approve' ? '/api/kyc-approve' : '/api/kyc-reject', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ userId }) });
                const apiResult = await response.json();
                if (apiResult.success) {
                    await VaultAlert.fire({ title: 'Success!', text: `User KYC ${action}d!`, icon: 'success', confirmButtonColor: '#3b82f6' });
                    const row = document.getElementById(`kyc-row-${userId}`);
                    if(row) { row.style.transition = 'all 0.5s ease'; row.style.opacity = '0'; row.style.transform = 'translateY(15px)'; setTimeout(() => { row.remove(); }, 500); }
                    setTimeout(() => { window.location.reload(); }, 1000);
                } else { VaultAlert.fire('Error', apiResult.error, 'error'); }
            } catch (e) { VaultAlert.fire('Error', 'API Connection Error!', 'error'); }
        }

        async function deleteKyc(userId) {
            const result = await VaultAlert.fire({ title: 'Permanently Delete?', text: "⚠️ DANGER: Are you sure you want to delete this user's KYC record?", icon: 'error', showCancelButton: true, confirmButtonColor: '#dc2626', cancelButtonColor: '#334155', confirmButtonText: '<i class="fa-solid fa-trash-can mr-2"></i> Delete' });
            if (!result.isConfirmed) return;
            try {
                const response = await fetch('/api/kyc-delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ userId }) });
                const apiResult = await response.json();
                if (apiResult.success) {
                    await VaultAlert.fire({ title: 'Deleted!', text: 'KYC record wiped.', icon: 'success', confirmButtonColor: '#3b82f6' });
                    window.location.reload();
                } else { VaultAlert.fire('Error', apiResult.error, 'error'); }
            } catch (e) { VaultAlert.fire('Error', 'API Connection Error!', 'error'); }
        }

        // --- 🔥 ZERO-READ SMART REFRESH SYSTEM 🔥 ---
        let currentServerTime = Date.now();
        let isSyncPaused = false;
        let syncInterval;

        function startSmartSync() {
            syncInterval = setInterval(async () => {
                if (!isSyncPaused) {
                    try {
                        const response = await fetch('/api/check-updates');
                        const data = await response.json();
                        if (data.timestamp > currentServerTime) { console.log("New data detected! Refreshing..."); window.location.reload(); }
                    } catch (error) { console.log("Update check paused/failed."); }
                }
            }, 5000);
        }

        function toggleSmartSync() {
            const icon = document.getElementById('refresh-icon'); const statusText = document.getElementById('sync-status'); isSyncPaused = !isSyncPaused;
            if (isSyncPaused) { icon.className = 'fa-solid fa-pause text-slate-500'; statusText.innerText = 'Paused'; statusText.className = 'text-slate-500'; } 
            else { icon.className = 'fa-solid fa-bolt text-green-500 animate-pulse'; statusText.innerText = 'Active'; statusText.className = 'text-green-400'; currentServerTime = Date.now(); }
        }

        function pauseOnModalOpen() { isSyncPaused = true; document.getElementById('refresh-icon').className = 'fa-solid fa-pause text-slate-500'; document.getElementById('sync-status').innerText = 'Paused'; document.getElementById('sync-status').className = 'text-slate-500'; }
        function resumeOnModalClose() { isSyncPaused = false; document.getElementById('refresh-icon').className = 'fa-solid fa-bolt text-green-500 animate-pulse'; document.getElementById('sync-status').innerText = 'Active'; document.getElementById('sync-status').className = 'text-green-400'; currentServerTime = Date.now(); }
        startSmartSync();

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar'); const overlay = document.getElementById('sidebar-overlay'); const arrowIcon = document.getElementById('menu-arrow-icon');
            if (!sidebar.classList.contains('-translate-x-full')) { sidebar.classList.add('-translate-x-full'); overlay.classList.remove('active'); overlay.classList.add('opacity-0'); arrowIcon.className = 'fa-solid fa-chevron-right text-lg'; } 
            else { sidebar.classList.remove('-translate-x-full'); overlay.classList.add('active'); overlay.classList.remove('opacity-0'); arrowIcon.className = 'fa-solid fa-chevron-left text-lg'; }
        }

        function showTab(tabId, btn) {
            document.getElementById('dashboard-view').classList.add('hidden-section'); 
            document.getElementById('settings-view').classList.add('hidden-section'); 
            document.getElementById('price-view').classList.add('hidden-section'); 
            document.getElementById('kyc-view').classList.add('hidden-section'); 
            document.getElementById('wallet-view').classList.add('hidden-section'); 
            document.getElementById('logs-view').classList.add('hidden-section'); 
            
            const selectedTab = document.getElementById(tabId);
            selectedTab.classList.remove('hidden-section'); selectedTab.classList.remove('fade-in'); void selectedTab.offsetWidth; selectedTab.classList.add('fade-in');
            document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active')); btn.classList.add('active');
            
            const titles = { 
                'dashboard-view': 'Executive Analytics', 
                'settings-view': 'Vault Settings', 
                'kyc-view': 'Verified Users Database', 
                'price-view': 'Market Prices',
                'wallet-view': 'Secure Wallet Details',
                'logs-view': 'Complete Transaction Logs' 
            };
            document.getElementById('page-title').innerText = titles[tabId];
            if (window.innerWidth < 1024) toggleSidebar();
        }

        function switchLogTab(tabId) {
            document.getElementById('kyc-logs').classList.add('hidden');
            document.getElementById('non-kyc-logs').classList.add('hidden');
            document.getElementById('kyc-stats').classList.add('hidden');
            document.getElementById('non-kyc-stats').classList.add('hidden');
            
            document.getElementById('btn-kyc-logs').className = 'text-slate-500 hover:text-slate-300 font-bold uppercase tracking-widest pb-2 px-2 transition duration-300';
            document.getElementById('btn-non-kyc-logs').className = 'text-slate-500 hover:text-slate-300 font-bold uppercase tracking-widest pb-2 px-2 transition duration-300';
            
            document.getElementById(tabId).classList.remove('hidden');
            
            if (tabId === 'kyc-logs') {
                document.getElementById('btn-kyc-logs').className = 'text-green-400 font-black uppercase tracking-widest border-b-2 border-green-500 pb-2 px-2 transition duration-300';
                document.getElementById('kyc-stats').classList.remove('hidden');
            } else {
                document.getElementById('btn-non-kyc-logs').className = 'text-orange-400 font-black uppercase tracking-widest border-b-2 border-orange-500 pb-2 px-2 transition duration-300';
                document.getElementById('non-kyc-stats').classList.remove('hidden');
            }
        }

        function openCustomVolModal() {
            pauseOnModalOpen();
            const modal = document.getElementById('customVolModal');
            const content = document.getElementById('customVolModalContent');
            
            // Purana data clear karein
            document.getElementById('cv-start').value = '';
            document.getElementById('cv-end').value = '';
            document.getElementById('cv-result-box').classList.add('hidden');
            
            modal.classList.remove('hidden');
            setTimeout(() => { content.classList.remove('scale-95', 'opacity-0'); content.classList.add('scale-100', 'opacity-100'); }, 10);
        }

        function closeCustomVolModal() {
            resumeOnModalClose();
            const modal = document.getElementById('customVolModal');
            const content = document.getElementById('customVolModalContent');
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { modal.classList.add('hidden'); }, 300);
        }

        function calculateCustomVolume() {
            const startVal = document.getElementById('cv-start').value;
            const endVal = document.getElementById('cv-end').value;
            
            if (!startVal || !endVal) {
                VaultAlert.fire('Oops!', 'Please select both Start and End dates.', 'warning');
                return;
            }

            // Dates set karein taaki poora din cover ho
            const startDate = new Date(startVal);
            startDate.setHours(0, 0, 0, 0);
            
            const endDate = new Date(endVal);
            endDate.setHours(23, 59, 59, 999);

            if (startDate > endDate) {
                VaultAlert.fire('Invalid Date', 'Start Date cannot be after End Date.', 'error');
                return;
            }

            let totalVol = 0;
            let totalFee = 0;
            let tradeCount = 0;

            // Har trade ko filter karke sum nikalna
            allLogsDataClient.forEach(trade => {
                if (trade.closedAt && trade.closedAt._seconds) {
                    const tradeDate = new Date(trade.closedAt._seconds * 1000);
                    if (tradeDate >= startDate && tradeDate <= endDate) {
                        totalVol += (trade.amountUsd || 0);
                        totalFee += (trade.fee || 0);
                        tradeCount++;
                    }
                }
            });

            // Result HTML mein push karna
            document.getElementById('cv-total-vol').innerText = '$' + totalVol.toLocaleString(undefined, { maximumFractionDigits: 2 });
            document.getElementById('cv-total-trades').innerText = tradeCount;
            document.getElementById('cv-total-fee').innerText = '$' + totalFee.toLocaleString(undefined, { maximumFractionDigits: 2 });
            
            document.getElementById('cv-result-box').classList.remove('hidden');
            document.getElementById('cv-result-box').classList.add('fade-in');
        }

        // --- 📋 COPY TO CLIPBOARD FUNCTION ---
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Copied to clipboard!',
                    showConfirmButton: false,
                    timer: 2000,
                    background: '#0f172a',
                    color: '#f8fafc',
                    customClass: { popup: 'border border-slate-700 shadow-xl' }
                });
            });
        }

        function openTxModal(index) {
            pauseOnModalOpen();
            const trade = recentTrades[index];
            if(!trade) return;
            document.getElementById('modal-avatar').innerText = trade.username.charAt(0).toUpperCase(); document.getElementById('modal-username').innerText = trade.username;
            let dateStr = "Date Not Available"; if (trade.closedAt && trade.closedAt._seconds) dateStr = new Date(trade.closedAt._seconds * 1000).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', dateStyle: 'medium', timeStyle: 'short' });
            document.getElementById('modal-date').innerText = dateStr;
            const actionEl = document.getElementById('modal-action');
            if(trade.tradeType === 'Buy') actionEl.innerHTML = `<span class="text-green-400"><i class="fa-solid fa-arrow-down mr-1"></i> BUY</span> <span class="text-slate-400 text-xs sm:text-sm ml-1">via ${trade.networkOrMethod}</span>`;
            else actionEl.innerHTML = `<span class="text-red-400"><i class="fa-solid fa-arrow-up mr-1"></i> SELL</span> <span class="text-slate-400 text-xs sm:text-sm ml-1">via ${trade.networkOrMethod}</span>`;
            document.getElementById('modal-amount').innerText = '$' + (trade.amountUsd ? trade.amountUsd.toLocaleString() : '0');
            document.getElementById('modal-details').innerText = trade.userReceivingDetails || "No details provided by the user."; document.getElementById('modal-closedBy').innerText = trade.closedBy || "Admin";
            const modal = document.getElementById('txModal'); const content = document.getElementById('txModalContent');
            modal.classList.remove('hidden'); setTimeout(() => { content.classList.remove('scale-95', 'opacity-0'); content.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closeTxModal() {
            resumeOnModalClose(); const modal = document.getElementById('txModal'); const content = document.getElementById('txModalContent');
            content.classList.remove('scale-100', 'opacity-100'); content.classList.add('scale-95', 'opacity-0'); setTimeout(() => { modal.classList.add('hidden'); }, 300);
        }

        function openKycModal() { pauseOnModalOpen(); const modal = document.getElementById('kycModal'); const content = document.getElementById('kycModalContent'); modal.classList.remove('hidden'); setTimeout(() => { content.classList.remove('scale-95', 'opacity-0'); content.classList.add('scale-100', 'opacity-100'); }, 10); }
        function closeKycModal() { resumeOnModalClose(); const modal = document.getElementById('kycModal'); const content = document.getElementById('kycModalContent'); content.classList.remove('scale-100', 'opacity-100'); content.classList.add('scale-95', 'opacity-0'); setTimeout(() => { modal.classList.add('hidden'); }, 300); }

        function openUserModal(docId) {
            pauseOnModalOpen(); const user = allKycData.find(u => u.id === docId); if(!user) return;
            document.getElementById('ud-avatar').innerText = (user.name || user.username || 'U').charAt(0).toUpperCase();
            document.getElementById('ud-name').innerText = user.name || 'Name Not Provided'; document.getElementById('ud-username').innerText = '@' + (user.username || user.discordContact || 'Unknown'); document.getElementById('ud-id').innerText = user.discordId || 'N/A';
            const statusEl = document.getElementById('ud-status'); statusEl.innerText = user.status || 'Pending'; statusEl.className = 'font-black text-sm ' + (user.status === 'Approved' ? 'text-green-400' : (user.status === 'Rejected' ? 'text-red-400' : 'text-yellow-400'));
            document.getElementById('ud-type').innerText = user.kycType || 'Basic Verification'; document.getElementById('ud-info').innerText = user.paymentInfo && user.paymentInfo !== 'N/A' ? user.paymentInfo : 'No additional information recorded.';
            let dateStr = "Not Available"; if (user.createdAt && user.createdAt._seconds) dateStr = new Date(user.createdAt._seconds * 1000).toLocaleDateString('en-IN'); else if (user.updatedAt && user.updatedAt._seconds) dateStr = new Date(user.updatedAt._seconds * 1000).toLocaleDateString('en-IN');
            document.getElementById('ud-date').innerText = dateStr;
            const modal = document.getElementById('userDetailsModal'); const content = document.getElementById('userDetailsModalContent');
            modal.classList.remove('hidden'); setTimeout(() => { content.classList.remove('scale-95', 'opacity-0'); content.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closeUserModal() { resumeOnModalClose(); const modal = document.getElementById('userDetailsModal'); const content = document.getElementById('userDetailsModalContent'); content.classList.remove('scale-100', 'opacity-100'); content.classList.add('scale-95', 'opacity-0'); setTimeout(() => { modal.classList.add('hidden'); }, 300); }

        function openDocs(username, photosStr) { 
            document.getElementById('docModalTitle').innerHTML = `<i class="fa-solid fa-folder-open text-blue-500 mr-3"></i> ${username}'s Documents`; 
            
            const container = document.getElementById('photoContainer');
            container.innerHTML = ''; // Purani photo hata do
            
            if (photosStr) {
                const photos = photosStr.split(','); // Comma se alag karke array banao
                photos.forEach((url, idx) => {
                    container.innerHTML += `
                        <div class="bg-slate-900/60 p-4 rounded-xl border border-slate-700 shadow-inner w-full flex flex-col items-center">
                            <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-3 text-center bg-slate-800/50 py-2 px-4 rounded w-full">Document ${idx + 1}</h4>
                            <a href="${url}" target="_blank" title="Click to view full image">
                                <img src="${url}" class="w-full rounded-lg object-cover h-48 sm:h-64 transition hover:scale-105 border border-slate-700" alt="Document ${idx+1}">
                            </a>
                        </div>
                    `;
                });
            } else {
                container.innerHTML = `<p class="text-slate-400 italic">No documents found.</p>`;
            }
            
            document.getElementById('photoModal').classList.remove('hidden'); 
        }
        function closeDocs() { document.getElementById('photoModal').classList.add('hidden'); }

        const ctxBar = document.getElementById('volumeChart').getContext('2d');
        const gradientLine = ctxBar.createLinearGradient(0, 0, 0, 300);
        gradientLine.addColorStop(0, 'rgba(239, 68, 68, 0.4)'); gradientLine.addColorStop(1, 'rgba(239, 68, 68, 0.0)');
        new Chart(ctxBar, { type: 'line', data: { labels: ['Daily (24h)', 'Weekly (7d)', 'Monthly (30d)'], datasets: [{ label: 'Revenue ($)', data: [Number('<%= dailyVol %>'), Number('<%= weeklyVol %>'), Number('<%= monthlyVol %>')], borderColor: '#ef4444', backgroundColor: gradientLine, borderWidth: 3, fill: true, tension: 0.4, pointBackgroundColor: '#0f172a', pointBorderColor: '#ef4444', pointBorderWidth: 2, pointRadius: 5, pointHoverRadius: 7 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.03)', drawBorder: false }, ticks: { color: '#64748b', font: { family: 'Outfit', weight: '600' } }, border: { display: false } }, x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { family: 'Outfit', weight: '800' } }, border: { display: false } } } } });

        const ctxDoughnut = document.getElementById('ratioChart').getContext('2d');
        const buyV = Number('<%= buyVol %>'), sellV = Number('<%= sellVol %>');
        
        // 🔥 Percentage Calculate Karna
        const totalVSum = buyV + sellV;
        const buyPercent = totalVSum > 0 ? Math.round((buyV / totalVSum) * 100) : 0;
        const sellPercent = totalVSum > 0 ? Math.round((sellV / totalVSum) * 100) : 0;

        new Chart(ctxDoughnut, { 
            type: 'doughnut', 
            data: { 
                // 🔥 Labels mein percentage add kar diya
                labels: [`Buy (INR in) : ${buyPercent}%`, `Sell (Crypto out) : ${sellPercent}%`], 
                datasets: [{ 
                    data: [buyV === 0 && sellV === 0 ? 1 : buyV, buyV === 0 && sellV === 0 ? 1 : sellV], 
                    backgroundColor: ['#22c55e', '#ef4444'], 
                    borderColor: '#0f172a', 
                    borderWidth: 5 
                }] 
            }, 
            options: { 
                responsive: true, 
                maintainAspectRatio: false, 
                cutout: '75%', 
                plugins: { 
                    legend: { 
                        position: 'bottom', 
                        labels: { color: '#94a3b8', font: { family:'Outfit', weight:'800', size: 12 }, padding: 20 } 
                    },
                    // 🔥 Hover karne par exact Amount ($) dikhayega
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return ' Amount: $' + context.raw.toLocaleString();
                            }
                        }
                    }
                } 
            } 
        });
        const calData = <%- calendarData %>, monthDataRaw = <%- monthWiseData %>;
        new Chart(document.getElementById('monthlyBarChart').getContext('2d'), { type: 'bar', data: { labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'], datasets: [{ label: 'Volume ($)', data: monthDataRaw, backgroundColor: 'rgba(99, 102, 241, 0.5)', borderColor: 'rgba(99, 102, 241, 1)', borderWidth: 1, borderRadius: 4, hoverBackgroundColor: 'rgba(99, 102, 241, 0.8)' }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)', drawBorder: false }, ticks: { color: '#64748b', font: { family: 'Outfit', weight: '600' } } }, x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { family: 'Outfit', weight: '800' } }, border: { display: false } } } } });

        const currentWeekData = [0, 0, 0, 0, 0, 0, 0], todayForWeek = new Date(), dayOfWeek = todayForWeek.getDay();
        const diffToMonday = todayForWeek.getDate() - dayOfWeek + (dayOfWeek === 0 ? -6 : 1);
        const mondayDate = new Date(todayForWeek.setDate(diffToMonday));
        for (let i = 0; i < 7; i++) { const d = new Date(mondayDate); d.setDate(mondayDate.getDate() + i); currentWeekData[i] = calData[`${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`] || 0; }
        new Chart(document.getElementById('weeklyBarChart').getContext('2d'), { type: 'bar', data: { labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'], datasets: [{ label: 'Volume ($)', data: currentWeekData, backgroundColor: 'rgba(14, 165, 233, 0.4)', borderColor: 'rgba(14, 165, 233, 0.8)', borderWidth: 1, borderRadius: 4, hoverBackgroundColor: 'rgba(14, 165, 233, 1)' }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(context) { return '$' + context.raw.toLocaleString(); } } } }, scales: { y: { display: false, beginAtZero: true }, x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { family: 'Outfit', weight: '700', size: 10 } }, border: { display: false } } } } });

        const calendarGridContainer = document.getElementById('calendar-heatmap-grid'), monthYearLabel = document.getElementById('calendar-month-year'), tooltip = document.getElementById('heatmap-tooltip'), tDate = document.getElementById('tooltip-date'), tVol = document.getElementById('tooltip-vol'), todayObj = new Date();
        let currentMonth = todayObj.getMonth(), currentYear = todayObj.getFullYear();
        function isSameDay(d1, d2) { return d1.getFullYear() === d2.getFullYear() && d1.getMonth() === d2.getMonth() && d1.getDate() === d2.getDate(); }

        window.changeMonth = function(delta) { currentMonth += delta; if (currentMonth > 11) { currentMonth = 0; currentYear++; } else if (currentMonth < 0) { currentMonth = 11; currentYear--; } renderCalendar(currentMonth, currentYear); }

        function renderCalendar(month, year) {
            monthYearLabel.innerText = `${['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'][month]} ${year}`;
            const firstDayOfMonth = new Date(year, month, 1).getDay(), daysInMonth = new Date(year, month + 1, 0).getDate(), heatmapHTML = [], prevMonthDate = new Date(year, month, 0), prevMonthDays = prevMonthDate.getDate();
            for (let i = firstDayOfMonth - 1; i >= 0; i--) heatmapHTML.push(`<div class="p-1.5 flex flex-col aspect-square border border-slate-700/50 rounded-md bg-slate-800/40 text-slate-500 opacity-40"><span class="font-bold text-[9px] self-center">${prevMonthDays - i}</span></div>`);
            for (let dayNumber = 1; dayNumber <= daysInMonth; dayNumber++) {
                const d = new Date(year, month, dayNumber), vol = calData[`${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`] || 0;
                const todayClass = isSameDay(d, todayObj) ? "border-red-500 shadow-[0_0_10px_rgba(239,68,68,0.3)]" : "";
                let colorClass = "bg-slate-800/60 border-slate-700/50 text-slate-300", volTextHTML = "";
                if (vol > 0 && vol <= 500) { colorClass = "bg-emerald-900 border-emerald-800 hover:border-emerald-400 text-slate-300"; volTextHTML = `<span class="font-black text-glow-green text-green-400 text-[9px] self-center">$${vol.toLocaleString()}</span>`; } 
                else if (vol > 500 && vol <= 2000) { colorClass = "bg-emerald-600 border-emerald-500 hover:border-white text-slate-100"; volTextHTML = `<span class="font-black text-glow-green text-green-300 text-[9px] self-center">$${vol.toLocaleString()}</span>`; } 
                else if (vol > 2000) { colorClass = "bg-emerald-400 border-emerald-300 shadow-[0_0_8px_rgba(52,211,153,0.5)] hover:border-white text-glow-green text-white"; volTextHTML = `<span class="font-black text-glow-green text-green-100 text-[9px] self-center">$${vol.toLocaleString()}</span>`; }
                heatmapHTML.push(`<div class="calendar-day p-1.5 flex flex-col justify-between aspect-square border rounded-md transition duration-200 cursor-pointer ${todayClass} ${colorClass}" data-date="${d.toDateString()}" data-vol="$${vol.toLocaleString()}"><span class="font-black text-xs self-center">${dayNumber}</span>${volTextHTML}</div>`);
            }
            const cellsToPad = (7 * (Math.ceil(heatmapHTML.length / 7))) - heatmapHTML.length;
            for (let i = 1; i <= cellsToPad; i++) heatmapHTML.push(`<div class="p-1.5 flex flex-col aspect-square border border-slate-700/50 rounded-md bg-slate-800/40 text-slate-500 opacity-40"><span class="font-bold text-[9px] self-center">${i}</span></div>`);
            
            calendarGridContainer.innerHTML = heatmapHTML.join('');
            document.querySelectorAll('.calendar-day').forEach(box => {
                box.addEventListener('mouseenter', () => { tDate.innerText = box.getAttribute('data-date'); tVol.innerText = 'Volume: ' + box.getAttribute('data-vol'); const rect = box.getBoundingClientRect(); tooltip.style.left = (rect.left + rect.width / 2) + 'px'; tooltip.style.top = (rect.top - 8) + 'px'; tooltip.classList.remove('hidden'); setTimeout(() => tooltip.classList.remove('opacity-0'), 10); });
                box.addEventListener('mouseleave', () => { tooltip.classList.add('opacity-0'); setTimeout(() => tooltip.classList.add('hidden'), 200); });
            });
        }
        renderCalendar(currentMonth, currentYear);

        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll('.animate-counter').forEach(counter => {
                const target = +counter.getAttribute('data-target'), prefix = counter.getAttribute('data-prefix') || '';
                if (target === 0) return counter.innerText = prefix + '0';
                let current = 0; const increment = target / (1500 / 16);
                const updateCounter = () => { current += increment; if (current < target) { counter.innerText = prefix + Math.ceil(current).toLocaleString(); requestAnimationFrame(updateCounter); } else { counter.innerText = prefix + target.toLocaleString(); } };
                updateCounter();
            });
        });
    </script>
</body>
</html>