<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Vault | Secure Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-900 flex items-center justify-center min-h-screen p-4" style="background-image: radial-gradient(circle at center, #1e293b, #020617);">

    <div class="bg-slate-800/50 backdrop-blur-md border border-slate-700 p-8 rounded-2xl shadow-[0_0_40px_rgba(0,0,0,0.5)] w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-red-700 tracking-widest uppercase mb-2">
                <i class="fa-solid fa-lock text-red-600 mr-2"></i> The Vault
            </h1>
            <p class="text-slate-400 text-sm font-medium">Restricted Access. Enter Credentials.</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-500/10 border border-red-500 text-red-500 p-3 rounded-lg mb-6 text-sm text-center font-bold animate-pulse">
                <i class="fa-solid fa-triangle-exclamation mr-1"></i> <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-slate-400 text-xs font-bold uppercase mb-2 tracking-wider">Username</label>
                <div class="relative">
                    <i class="fa-solid fa-user absolute left-4 top-3.5 text-slate-500"></i>
                    <input type="text" name="username" class="w-full bg-slate-900 border border-slate-700 text-white rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:border-red-500 transition" placeholder="Admin ID" required>
                </div>
            </div>
            <div>
                <label class="block text-slate-400 text-xs font-bold uppercase mb-2 tracking-wider">Passcode</label>
                <div class="relative">
                    <i class="fa-solid fa-key absolute left-4 top-3.5 text-slate-500"></i>
                    <input type="password" name="password" class="w-full bg-slate-900 border border-slate-700 text-white rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:border-red-500 transition" placeholder="••••••••" required>
                </div>
            </div>
            
            <button type="submit" class="w-full bg-gradient-to-r from-red-600 to-red-800 hover:from-red-500 hover:to-red-700 text-white font-black uppercase tracking-widest py-3.5 rounded-xl transition duration-300 shadow-[0_0_15px_rgba(220,38,38,0.4)] mt-4">
                Enter The Vault
            </button>
        </form>
    </div>

</body>
</html>